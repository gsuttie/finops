@inject IFeatureFlagService FeatureFlagService
@implements IDisposable
@using FinOps.Services

<MudNavMenu>
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>

    @if (FeatureFlagService.Flags.Budgets)
    {
        <MudNavGroup Title="Budgets" Icon="@Icons.Material.Filled.AccountBalance" Expanded="false">
            <MudNavLink Href="budgets/subscriptions" Match="NavLinkMatch.All">Subscription Budgets</MudNavLink>
            <MudNavLink Href="budgets/resource-groups" Match="NavLinkMatch.All">Resource Group Budgets</MudNavLink>
            <MudNavLink Href="budgets/overview" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.ViewList">Budget Overview</MudNavLink>
        </MudNavGroup>
    }

    @if (FeatureFlagService.Flags.CostManagement)
    {
        <MudNavGroup Title="Cost Management" Icon="@Icons.Material.Filled.AttachMoney" Expanded="false">
            <MudNavLink Href="dashboard/overview" Match="NavLinkMatch.All">Overview Dashboard</MudNavLink>
            <MudNavLink Href="costs/overview" Match="NavLinkMatch.All">Cost Overview</MudNavLink>
            <MudNavLink Href="costs/dashboard" Match="NavLinkMatch.All">Cost Dashboard</MudNavLink>
        </MudNavGroup>
    }

    @if (FeatureFlagService.Flags.Tagging)
    {
        <MudNavGroup Title="Tagging" Icon="@Icons.Material.Filled.Label" Expanded="false">
            <MudNavLink Href="tagging" Match="NavLinkMatch.All">Resource Tagging</MudNavLink>
            <MudNavLink Href="tagging/costs" Match="NavLinkMatch.All">Costs by Tagging</MudNavLink>
            @if (FeatureFlagService.Flags.Policy)
            {
                <MudNavLink Href="policy" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Policy">Policy</MudNavLink>
            }
        </MudNavGroup>
    }

    <MudNavGroup Title="Monthly Review" Icon="@Icons.Material.Filled.CalendarMonth" Expanded="false">
        @if (FeatureFlagService.Flags.SpendTrends)
        {
            <MudNavLink Href="costs/spend-trends" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.ShowChart">Spend Trends</MudNavLink>
        }
        @if (FeatureFlagService.Flags.Advisor)
        {
            <MudNavLink Href="advisor" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Lightbulb">Advisor</MudNavLink>
        }
        @if (FeatureFlagService.Flags.OrphanedResources)
        {
            <MudNavLink Href="orphaned-resources" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.DeleteSweep">Orphaned Resources</MudNavLink>
        }
        @if (FeatureFlagService.Flags.LoggingUsage)
        {
            <MudNavLink Href="logging-usage" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Analytics">Logging Usage</MudNavLink>
        }
        @if (FeatureFlagService.Flags.Rightsizing)
        {
            <MudNavLink Href="rightsizing" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AutoAwesome">Rightsizing</MudNavLink>
        }
        @if (FeatureFlagService.Flags.ReservationCandidates)
        {
            <MudNavLink Href="costs/reservation-candidates" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Savings">Reservation Candidates</MudNavLink>
        }
        @if (FeatureFlagService.Flags.HybridBenefit)
        {
            <MudNavLink Href="costs/hybrid-benefit" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.CardGiftcard">Hybrid Benefit</MudNavLink>
        }
    </MudNavGroup>

    <MudNavGroup Title="Other" Icon="@Icons.Material.Filled.MoreHoriz" Expanded="false">
        @if (FeatureFlagService.Flags.CostQuestions)
        {
            <MudNavLink Href="cost-questions" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.QuestionAnswer">Cost Questions</MudNavLink>
        }
        @if (FeatureFlagService.Flags.Upsell)
        {
            <MudNavLink Href="upsell" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.TrendingUp">Upsell Opportunities</MudNavLink>
        }
        @if (FeatureFlagService.Flags.Security)
        {
            <MudNavLink Href="security-recommendations" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Shield">Security Recommendations</MudNavLink>
        }
        @if (FeatureFlagService.Flags.PrivateEndpoints)
        {
            <MudNavLink Href="private-endpoints" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Lock">Private Endpoints</MudNavLink>
        }
        @if (FeatureFlagService.Flags.ServiceRetirements)
        {
            <MudNavLink Href="service-retirements" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.EventBusy">Service Retirements</MudNavLink>
        }
        @if (FeatureFlagService.Flags.Maturity)
        {
            <MudNavLink Href="maturity" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Insights">Maturity Score</MudNavLink>
        }
        @if (FeatureFlagService.Flags.Carbon)
        {
            <MudNavLink Href="carbon" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.EnergySavingsLeaf">Carbon</MudNavLink>
        }
        @if (FeatureFlagService.Flags.Themes)
        {
            <MudNavLink Href="themes" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Palette">Themes</MudNavLink>
        }
    </MudNavGroup>

    @if (FeatureFlagService.Flags.MonthlyReport)
    {
        <MudNavGroup Title="Monthly Report" Icon="@Icons.Material.Filled.Assessment" Expanded="false">
            <MudNavLink Href="monthly-report/reservation-candidates" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Savings">Reservation Candidates</MudNavLink>
        </MudNavGroup>
    }

    <MudNavLink Href="admin" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AdminPanelSettings">Admin</MudNavLink>
</MudNavMenu>

@code {
    protected override void OnInitialized()
    {
        FeatureFlagService.OnFlagsChanged += OnFlagsChanged;
    }

    private void OnFlagsChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        FeatureFlagService.OnFlagsChanged -= OnFlagsChanged;
    }
}
