@inherits LayoutComponentBase

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">FinOps</MudText>
        <MudSpacer />
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="ToggleDarkMode" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pa-4">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#0078D4",        // Azure blue
            PrimaryDarken = "#005A9E",
            PrimaryLighten = "#50A0FF",
            Secondary = "#00B4FF",
            AppbarBackground = "#0078D4",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#0078D4",        // Azure blue
            PrimaryDarken = "#005A9E",
            PrimaryLighten = "#50A0FF",
            Secondary = "#00B4FF",
            AppbarBackground = "#0078D4",
        }
    };

    /// <summary>
    /// Toggles the side navigation drawer between open and closed states.
    /// </summary>
    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    /// <summary>
    /// Toggles between dark mode and light mode.
    /// </summary>
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;
}
