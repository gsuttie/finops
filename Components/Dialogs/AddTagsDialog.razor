@using FinOps.Models

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Label" Class="mr-2" />
            Apply Tags
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">
            Tags will be merged — existing tags on resources will not be removed.
        </MudText>

        @for (var i = 0; i < _model.Tags.Count; i++)
        {
            var index = i;
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                <MudTextField T="string" @bind-Value="_model.Tags[index].Key"
                              Label="Key" Variant="Variant.Outlined" Immediate="true"
                              MaxLength="512" Style="flex: 1;" />
                <MudTextField T="string" @bind-Value="_model.Tags[index].Value"
                              Label="Value" Variant="Variant.Outlined" Immediate="true"
                              MaxLength="256" Style="flex: 1;" />
                @if (_model.Tags.Count > 1)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Remove" Color="Color.Error"
                                   Size="Size.Small" OnClick="@(() => RemoveTag(index))" />
                }
            </MudStack>
        }

        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="AddTag" Class="mt-1">
            Add another tag
        </MudButton>

        @if (_validationError is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true">@_validationError</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">
            Apply Tags
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    /// <summary>
    /// The MudDialog instance provided by the MudBlazor dialog system.
    /// </summary>
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    private readonly TagFormModel _model = new();
    private string? _validationError;

    /// <summary>
    /// Appends a new empty tag key/value row to the form.
    /// </summary>
    private void AddTag()
    {
        _model.Tags.Add(new TagEntry());
    }

    /// <summary>
    /// Removes the tag entry at the specified index.
    /// </summary>
    /// <param name="index">Zero-based index of the tag row to remove.</param>
    private void RemoveTag(int index)
    {
        _model.Tags.RemoveAt(index);
    }

    /// <summary>
    /// Cancels the dialog without returning a result.
    /// </summary>
    private void Cancel() => MudDialog.Cancel();

    /// <summary>
    /// Validates the tag entries (no empty keys, no duplicates, within Azure tag limits)
    /// and closes the dialog with a dictionary of tag key/value pairs on success.
    /// </summary>
    private void Submit()
    {
        _validationError = null;

        // Remove completely empty rows
        _model.Tags.RemoveAll(t => string.IsNullOrWhiteSpace(t.Key) && string.IsNullOrWhiteSpace(t.Value));

        if (_model.Tags.Count == 0)
        {
            _validationError = "At least one tag is required.";
            _model.Tags.Add(new TagEntry());
            return;
        }

        // Check for empty keys
        if (_model.Tags.Any(t => string.IsNullOrWhiteSpace(t.Key)))
        {
            _validationError = "All tag keys must be non-empty.";
            return;
        }

        // Check for duplicate keys
        var duplicates = _model.Tags
            .GroupBy(t => t.Key.Trim(), StringComparer.OrdinalIgnoreCase)
            .Where(g => g.Count() > 1)
            .Select(g => g.Key)
            .ToList();

        if (duplicates.Count > 0)
        {
            _validationError = $"Duplicate tag keys: {string.Join(", ", duplicates)}";
            return;
        }

        // Check Azure limits (key max 512, value max 256)
        if (_model.Tags.Any(t => t.Key.Trim().Length > 512))
        {
            _validationError = "Tag key cannot exceed 512 characters.";
            return;
        }

        if (_model.Tags.Any(t => (t.Value ?? "").Length > 256))
        {
            _validationError = "Tag value cannot exceed 256 characters.";
            return;
        }

        var dict = _model.Tags.ToDictionary(t => t.Key.Trim(), t => t.Value?.Trim() ?? string.Empty);
        MudDialog.Close(DialogResult.Ok(dict));
    }
}
