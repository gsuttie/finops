<Router AppAssembly="typeof(Program).Assembly" NotFoundPage="typeof(Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <Navigating>
        <div style="display: flex; justify-content: center; align-items: center; height: 100vh; background: var(--mud-palette-background);">
            <MudPaper Elevation="3" Style="padding: 2rem; max-width: 600px;">
                <MudStack Spacing="3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                        <MudText Typo="Typo.h5">Loading FinOps Portal</MudText>
                    </MudStack>

                    <MudDivider />

                    <MudText Typo="Typo.h6" Color="Color.Primary">Available Areas:</MudText>

                    <MudGrid>
                        <MudItem xs="6">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.Home" Size="Size.Small" /> Home</MudText>
                                <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Small" /> Budgets</MudText>
                                <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" /> Cost Management</MudText>
                                <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.Label" Size="Size.Small" /> Tagging</MudText>
                                <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.Policy" Size="Size.Small" /> Policy</MudText>
                            </MudStack>
                        </MudItem>
                        <MudItem xs="6">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.DeleteSweep" Size="Size.Small" /> Orphaned Resources</MudText>
                                <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.Lightbulb" Size="Size.Small" /> Advisor</MudText>
                                <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" /> Security</MudText>
                                <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.EventBusy" Size="Size.Small" /> Service Retirements</MudText>
                                <MudText Typo="Typo.body2"><MudIcon Icon="@Icons.Material.Filled.Analytics" Size="Size.Small" /> Logging Usage</MudText>
                            </MudStack>
                        </MudItem>
                    </MudGrid>
                </MudStack>
            </MudPaper>
        </div>
    </Navigating>
</Router>
