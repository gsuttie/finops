@page "/cost-questions"
@implements IAsyncDisposable
@inject IFeatureFlagService FeatureFlagService
@inject ICopilotService CopilotService
@inject IJSRuntime JS
@using FinOps.Services

<PageTitle>Cost Questions</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8 pt-8" Style="height: calc(100vh - 120px); display: flex; flex-direction: column;">
    <MudText Typo="Typo.h4" Class="mb-1">
        <MudIcon Icon="@Icons.Material.Filled.QuestionAnswer" Class="mr-2" />Cost Questions
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Chat with an Azure FinOps expert powered by GitHub Copilot.
    </MudText>

    @if (!FeatureFlagService.Flags.CostQuestions)
    {
        <MudAlert Severity="Severity.Warning">
            The Cost Questions feature is currently disabled. Enable it from the
            <MudLink Href="admin">Admin</MudLink> page.
        </MudAlert>
    }
    else
    {
        <MudPaper Elevation="2" Style="border-radius: 12px; flex: 1; display: flex; flex-direction: column; overflow: hidden; min-height: 0;">

            @* ── Messages ── *@
            <div id="chat-scroll" style="flex: 1; overflow-y: auto; padding: 20px; min-height: 0;">

                @if (_initializing)
                {
                    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height: 100%;">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        <MudText Color="Color.Secondary">Starting Copilot session…</MudText>
                    </MudStack>
                }
                else if (_initError is not null)
                {
                    <MudAlert Severity="Severity.Error">@_initError</MudAlert>
                }
                else if (_messages.Count == 0)
                {
                    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height: 100%; opacity: 0.4;">
                        <MudIcon Icon="@Icons.Material.Filled.Chat" Style="font-size: 3rem;" />
                        <MudText>Ask anything about Azure costs and FinOps…</MudText>
                    </MudStack>
                }
                else
                {
                    @foreach (var msg in _messages)
                    {
                        <div style="display: flex; justify-content: @(msg.IsUser ? "flex-end" : "flex-start"); margin-bottom: 14px;">
                            <div style="max-width: 78%;">
                                @if (!msg.IsUser)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-left: 4px; margin-bottom: 3px; display: block;">
                                        Copilot
                                    </MudText>
                                }
                                <MudPaper Elevation="1" Style="@BubbleStyle(msg.IsUser)">
                                    <MudText Typo="Typo.body1" Style="white-space: pre-wrap; word-break: break-word;">@msg.Content</MudText>
                                </MudPaper>
                            </div>
                        </div>
                    }
                }

                @* Streaming bubble *@
                @if (_streaming)
                {
                    <div style="display: flex; justify-content: flex-start; margin-bottom: 14px;">
                        <div style="max-width: 78%;">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-left: 4px; margin-bottom: 3px; display: block;">
                                Copilot
                            </MudText>
                            <MudPaper Elevation="1" Style="@BubbleStyle(false)">
                                @if (string.IsNullOrEmpty(_streamingContent))
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                                }
                                else
                                {
                                    <MudText Typo="Typo.body1" Style="white-space: pre-wrap; word-break: break-word;">@_streamingContent</MudText>
                                }
                            </MudPaper>
                        </div>
                    </div>
                }

            </div>

            <MudDivider />

            @* ── Input ── *@
            <div style="padding: 12px 16px;">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
                    <MudTextField T="string"
                                  @bind-Value="_input"
                                  Placeholder="Ask about Azure costs… (Enter to send, Shift+Enter for newline)"
                                  Lines="1"
                                  AutoGrow="true"
                                  MaxLines="5"
                                  Variant="Variant.Outlined"
                                  Disabled="_streaming || _initializing || _initError is not null"
                                  Style="flex: 1; margin: 0;"
                                  Margin="Margin.Dense"
                                  @onkeydown="OnKeyDown" />
                    <MudIconButton Icon="@Icons.Material.Filled.Send"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   OnClick="SendAsync"
                                   Disabled="_streaming || _initializing || _initError is not null || string.IsNullOrWhiteSpace(_input)"
                                   Size="Size.Large"
                                   Style="margin-bottom: 2px;" />
                </MudStack>
            </div>

        </MudPaper>
    }
</MudContainer>

@code {
    private ICopilotChatSession? _chatSession;
    private bool _initializing = true;
    private string? _initError;

    private readonly List<ChatMessage> _messages = [];
    private string _input = string.Empty;
    private bool _streaming;
    private string _streamingContent = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (!FeatureFlagService.Flags.CostQuestions)
        {
            _initializing = false;
            return;
        }

        try
        {
            _chatSession = await CopilotService.CreateChatSessionAsync();
        }
        catch (Exception ex)
        {
            _initError = $"Failed to start Copilot session: {ex.Message}";
        }
        finally
        {
            _initializing = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await ScrollToBottomAsync();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendAsync();
    }

    private async Task SendAsync()
    {
        if (_chatSession is null || string.IsNullOrWhiteSpace(_input) || _streaming) return;

        var text = _input.Trim();
        _input = string.Empty;
        _streaming = true;
        _streamingContent = string.Empty;
        _messages.Add(new ChatMessage(text, IsUser: true));
        StateHasChanged();

        try
        {
            await _chatSession.SendAsync(text, delta =>
            {
                _streamingContent += delta;
                InvokeAsync(StateHasChanged);
            });

            _messages.Add(new ChatMessage(_streamingContent, IsUser: false));
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage($"Error: {ex.Message}", IsUser: false));
        }
        finally
        {
            _streaming = false;
            _streamingContent = string.Empty;
            StateHasChanged();
        }
    }

    private static string BubbleStyle(bool isUser) =>
        isUser
            ? "padding: 10px 14px; border-radius: 18px 18px 4px 18px; background: var(--mud-palette-primary); color: var(--mud-palette-primary-text);"
            : "padding: 10px 14px; border-radius: 18px 18px 18px 4px; background: var(--mud-palette-surface);";

    private async Task ScrollToBottomAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("eval",
                "var el = document.getElementById('chat-scroll'); if (el) el.scrollTop = el.scrollHeight;");
        }
        catch { /* ignore prerender */ }
    }

    public async ValueTask DisposeAsync()
    {
        if (_chatSession is not null)
            await _chatSession.DisposeAsync();
    }

    private record ChatMessage(string Content, bool IsUser);
}
