@page "/tagging"
@using FinOps.Models
@using FinOps.Services
@inject IAzureSubscriptionService SubscriptionService
@inject IResourceTaggingService TaggingService
@inject TenantClientManager TenantClientManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<Tagging> Logger

<PageTitle>Tagging</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Resource Tagging</MudText>

@* Tenant connection bar *@
<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
        @if (!string.IsNullOrEmpty(_homeTenantDisplayName))
        {
            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">
                @_homeTenantDisplayName
            </MudChip>
        }
        @foreach (var tenantId in TenantClientManager.ConnectedTenantIds)
        {
            <MudChip T="string" Color="Color.Secondary" Size="Size.Small" OnClose="@(async _ => await DisconnectTenant(tenantId))">
                @tenantId
            </MudChip>
        }
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="@OpenConnectTenantDialog">
            Connect Tenant
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Refresh" OnClick="@LoadSubscriptions">
            Refresh
        </MudButton>
    </MudStack>
</MudPaper>

@* Step 1: Select a subscription *@
<MudTable T="TenantSubscription" Items="@_filteredSubscriptions" Loading="@_loadingSubscriptions"
          Hover="true" Dense="true" Elevation="2" MultiSelection="true"
          SelectedItems="_selectedSubscriptions" SelectedItemsChanged="OnSubscriptionsChanged">
    <ToolBarContent>
        <MudText Typo="Typo.h6">1. Select Subscriptions</MudText>
        <MudSpacer />
        <MudTextField T="string" @bind-Value="_searchText" Placeholder="Search subscriptions..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium" Immediate="true" Class="mr-4" Style="max-width: 300px;" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Tenant</MudTh>
        <MudTh><MudTableSortLabel T="TenantSubscription" SortBy="@(new Func<TenantSubscription, object>(x => x.DisplayName))">Name</MudTableSortLabel></MudTh>
        <MudTh>Subscription ID</MudTh>
        <MudTh>State</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Tenant">
            <MudText Typo="Typo.body2"><strong>@context.TenantDisplayName</strong></MudText>
            <MudText Typo="Typo.caption" Style="font-family: monospace;">@context.TenantId</MudText>
        </MudTd>
        <MudTd DataLabel="Name">
            <MudLink Href="@GetAzurePortalUrl(context)" Target="_blank" Typo="Typo.body2">
                @context.DisplayName
            </MudLink>
        </MudTd>
        <MudTd DataLabel="Subscription ID">
            <MudLink Href="@GetAzurePortalUrl(context)" Target="_blank" Typo="Typo.body2" Style="font-family: monospace;">
                @context.SubscriptionId
            </MudLink>
        </MudTd>
        <MudTd DataLabel="State">
            <MudChip T="string" Color="@GetStateColor(context.State)" Size="Size.Small">
                @context.State
            </MudChip>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        @if (_loadError is not null)
        {
            <MudText Color="Color.Error">@_loadError</MudText>
        }
        else
        {
            <MudText>No subscriptions found.</MudText>
        }
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Loading subscriptions...</MudText>
    </LoadingContent>
</MudTable>

@* Step 2: Select resource groups *@
@if (_selectedSubscriptions.Count > 0)
{
    <MudTable T="ResourceGroupInfo" Items="@_resourceGroups" MultiSelection="true"
              @bind-SelectedItems="_selectedResourceGroups" Loading="@_loadingResourceGroups"
              Hover="true" Dense="true" Elevation="2" Class="mt-4">
        <ToolBarContent>
            <MudText Typo="Typo.h6">2. Select Resource Groups</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Label"
                       OnClick="@OpenApplyTagsDialog">
                Apply Tags (@_selectedResourceGroups.Count selected)
            </MudButton>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel T="ResourceGroupInfo" SortBy="@(new Func<ResourceGroupInfo, object>(x => x.Name))">Name</MudTableSortLabel></MudTh>
            <MudTh>Subscription</MudTh>
            <MudTh><MudTableSortLabel T="ResourceGroupInfo" SortBy="@(new Func<ResourceGroupInfo, object>(x => x.Location ?? ""))">Location</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="ResourceGroupInfo" SortBy="@(new Func<ResourceGroupInfo, object>(x => x.ProvisioningState ?? ""))">State</MudTableSortLabel></MudTh>
            <MudTh>Existing Tags</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">
                @if (_rgSubscriptionMap.TryGetValue(context, out var rgSub))
                {
                    <MudLink Href="@GetResourceGroupPortalUrl(context, rgSub)" Target="_blank" Typo="Typo.body2">
                        @context.Name
                    </MudLink>
                }
                else
                {
                    @context.Name
                }
            </MudTd>
            <MudTd DataLabel="Subscription">
                @if (_rgSubscriptionMap.TryGetValue(context, out var sub))
                {
                    <MudLink Href="@GetAzurePortalUrl(sub)" Target="_blank" Typo="Typo.body2">
                        @sub.DisplayName
                    </MudLink>
                }
            </MudTd>
            <MudTd DataLabel="Location">@context.Location</MudTd>
            <MudTd DataLabel="State">@context.ProvisioningState</MudTd>
            <MudTd DataLabel="Existing Tags">
                @if (context.Tags.Count > 0)
                {
                    @foreach (var tag in context.Tags.Take(3))
                    {
                        <MudTooltip Text="@($"{tag.Key} = {tag.Value}")">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                @tag.Key
                            </MudChip>
                        </MudTooltip>
                    }
                    @if (context.Tags.Count > 3)
                    {
                        <MudTooltip Text="@string.Join("\n", context.Tags.Skip(3).Select(t => $"{t.Key} = {t.Value}"))">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                +@(context.Tags.Count - 3) more
                            </MudChip>
                        </MudTooltip>
                    }
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Tertiary">None</MudText>
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            @if (_rgLoadError is not null)
            {
                <MudText Color="Color.Error">@_rgLoadError</MudText>
            }
            else
            {
                <MudText>No resource groups found.</MudText>
            }
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Loading resource groups...</MudText>
        </LoadingContent>
    </MudTable>
}

@* Step 3: Results *@
@if (_results.Count > 0)
{
    <MudText Typo="Typo.h6" Class="mt-6 mb-2">
        Tagging Results
        @if (_applying)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ml-2" />
        }
    </MudText>
    <MudTable T="TagOperationResult" Items="@_results" Hover="true" Dense="true" Elevation="2">
        <HeaderContent>
            <MudTh>Resource</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Details</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Resource">@context.ResourceName</MudTd>
            <MudTd DataLabel="Type">@context.ResourceType</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@(context.Success ? Color.Success : Color.Error)" Size="Size.Small">
                    @(context.Success ? "Success" : "Failed")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Details">
                @if (!context.Success)
                {
                    <MudText Typo="Typo.body2" Color="Color.Error">@context.ErrorMessage</MudText>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<TenantSubscription> _subscriptions = [];
    private HashSet<TenantSubscription> _selectedSubscriptions = new();
    private List<ResourceGroupInfo> _resourceGroups = [];
    private HashSet<ResourceGroupInfo> _selectedResourceGroups = [];
    private Dictionary<ResourceGroupInfo, TenantSubscription> _rgSubscriptionMap = new();
    private List<TagOperationResult> _results = [];
    private bool _loadingSubscriptions = true;
    private bool _loadingResourceGroups;
    private bool _applying;
    private string? _loadError;
    private string? _rgLoadError;
    private string _searchText = string.Empty;
    private string? _homeTenantId;
    private string? _homeTenantDisplayName;

    /// <summary>
    /// Filters subscriptions by display name, subscription ID, tenant name, or tenant ID based on the search text.
    /// </summary>
    private IEnumerable<TenantSubscription> _filteredSubscriptions =>
        string.IsNullOrWhiteSpace(_searchText)
            ? _subscriptions
            : _subscriptions.Where(s =>
                s.DisplayName.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                s.SubscriptionId.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                (s.TenantDisplayName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                s.TenantId.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        (_homeTenantId, _homeTenantDisplayName) = await TenantClientManager.GetHomeTenantInfoAsync();
        await LoadSubscriptions();
    }

    /// <summary>
    /// Loads all subscriptions from the home tenant and any connected tenants.
    /// Resets selection and resource group state.
    /// </summary>
    private async Task LoadSubscriptions()
    {
        _loadingSubscriptions = true;
        _loadError = null;
        _selectedSubscriptions.Clear();
        _resourceGroups.Clear();
        _selectedResourceGroups.Clear();
        _rgSubscriptionMap.Clear();
        StateHasChanged();

        try
        {
            _subscriptions = (await SubscriptionService.GetSubscriptionsAsync()).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load subscriptions");
            _loadError = "Failed to load subscriptions.";
        }
        finally
        {
            _loadingSubscriptions = false;
        }
    }

    /// <summary>
    /// Handles subscription selection changes; loads resource groups for all selected subscriptions.
    /// </summary>
    private async Task OnSubscriptionsChanged(HashSet<TenantSubscription> selected)
    {
        _selectedSubscriptions = selected;
        _selectedResourceGroups.Clear();
        _results.Clear();
        _resourceGroups.Clear();
        _rgSubscriptionMap.Clear();

        if (selected.Count == 0) return;

        _loadingResourceGroups = true;
        _rgLoadError = null;
        StateHasChanged();

        try
        {
            foreach (var subscription in selected)
            {
                var rgs = (await TaggingService.GetResourceGroupsAsync(subscription)).ToList();
                foreach (var rg in rgs)
                {
                    _rgSubscriptionMap[rg] = subscription;
                }
                _resourceGroups.AddRange(rgs);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load resource groups");
            _rgLoadError = "Failed to load resource groups.";
            _resourceGroups.Clear();
            _rgSubscriptionMap.Clear();
        }
        finally
        {
            _loadingResourceGroups = false;
        }
    }

    /// <summary>
    /// Opens the Connect Tenant dialog and, on success, registers the new tenant and reloads subscriptions.
    /// </summary>
    private async Task OpenConnectTenantDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<FinOps.Components.Dialogs.ConnectTenantDialog>("Connect Tenant", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string tenantId })
        {
            Snackbar.Add($"Connected to tenant {tenantId}", Severity.Success);
            await LoadSubscriptions();
        }
    }

    /// <summary>
    /// Removes a connected tenant and reloads the subscription list.
    /// </summary>
    /// <param name="tenantId">The Azure AD tenant ID to disconnect.</param>
    private async Task DisconnectTenant(string tenantId)
    {
        TenantClientManager.DisconnectTenant(tenantId);
        Snackbar.Add($"Disconnected from tenant {tenantId}", Severity.Info);
        await LoadSubscriptions();
    }

    /// <summary>
    /// Opens the Apply Tags dialog and merges the submitted tags onto all selected resource groups.
    /// Reports per-resource progress in real time and reloads resource groups on completion.
    /// </summary>
    private async Task OpenApplyTagsDialog()
    {
        if (_applying) return;
        if (_selectedSubscriptions.Count == 0 || _selectedResourceGroups.Count == 0)
        {
            Snackbar.Add("Select at least one resource group first.", Severity.Warning);
            return;
        }

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<FinOps.Components.Dialogs.AddTagsDialog>("Apply Tags", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: Dictionary<string, string> tags })
        {
            _applying = true;
            _results.Clear();
            StateHasChanged();

            try
            {
                var allResults = new List<TagOperationResult>();

                // Group selected resource groups by their subscription
                var rgsBySubscription = _selectedResourceGroups
                    .Where(rg => _rgSubscriptionMap.ContainsKey(rg))
                    .GroupBy(rg => _rgSubscriptionMap[rg]);

                foreach (var group in rgsBySubscription)
                {
                    var results = await TaggingService.ApplyTagsAsync(
                        group.Key,
                        group.ToHashSet(),
                        tags,
                        onProgress: r =>
                        {
                            InvokeAsync(() =>
                            {
                                _results.Add(r);
                                StateHasChanged();
                            });
                        });
                    allResults.AddRange(results);
                }

                var succeeded = allResults.Count(r => r.Success);
                var failed = allResults.Count(r => !r.Success);

                if (failed == 0)
                    Snackbar.Add($"Tags applied to all {succeeded} resource(s)", Severity.Success);
                else
                    Snackbar.Add($"{succeeded} succeeded, {failed} failed", Severity.Warning);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error applying tags");
                Snackbar.Add("Error applying tags.", Severity.Error);
            }
            finally
            {
                _applying = false;
                await ReloadResourceGroups();
            }
        }
    }

    /// <summary>
    /// Reloads the resource groups for all selected subscriptions to refresh tag data.
    /// </summary>
    private async Task ReloadResourceGroups()
    {
        if (_selectedSubscriptions.Count == 0) return;

        _loadingResourceGroups = true;
        _selectedResourceGroups.Clear();
        _resourceGroups.Clear();
        _rgSubscriptionMap.Clear();
        StateHasChanged();

        try
        {
            foreach (var subscription in _selectedSubscriptions)
            {
                var rgs = (await TaggingService.GetResourceGroupsAsync(subscription)).ToList();
                foreach (var rg in rgs)
                {
                    _rgSubscriptionMap[rg] = subscription;
                }
                _resourceGroups.AddRange(rgs);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to reload resource groups");
            _rgLoadError = "Failed to reload resource groups.";
        }
        finally
        {
            _loadingResourceGroups = false;
        }
    }

    /// <summary>
    /// Maps a subscription state string to a MudBlazor color for visual indication.
    /// </summary>
    private static Color GetStateColor(string? state) => state switch
    {
        "Enabled" => Color.Success,
        "Disabled" => Color.Error,
        "Warned" => Color.Warning,
        _ => Color.Default
    };

    /// <summary>
    /// Generates the Azure portal URL for a subscription.
    /// </summary>
    private static string GetAzurePortalUrl(TenantSubscription subscription) =>
        $"https://portal.azure.com/#@{subscription.TenantId}/resource/subscriptions/{subscription.SubscriptionId}/overview";

    /// <summary>
    /// Generates the Azure portal URL for a resource group.
    /// </summary>
    private static string GetResourceGroupPortalUrl(ResourceGroupInfo resourceGroup, TenantSubscription subscription) =>
        $"https://portal.azure.com/#@{subscription.TenantId}/resource/subscriptions/{subscription.SubscriptionId}/resourceGroups/{resourceGroup.Name}/overview";
}
