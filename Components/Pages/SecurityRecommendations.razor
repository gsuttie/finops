@page "/security-recommendations"
@using FinOps.Models
@using FinOps.Services
@inject IAzureSubscriptionService SubscriptionService
@inject ISecurityRecommendationService SecurityRecommendationService
@inject TenantClientManager TenantClientManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Security Recommendations</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Security Recommendations</MudText>

@* Tenant connection bar *@
<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
        @if (!string.IsNullOrEmpty(_homeTenantDisplayName))
        {
            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">
                @_homeTenantDisplayName
            </MudChip>
        }
        @foreach (var tenantId in TenantClientManager.ConnectedTenantIds)
        {
            <MudChip T="string" Color="Color.Secondary" Size="Size.Small" OnClose="@(async _ => await DisconnectTenant(tenantId))">
                @tenantId
            </MudChip>
        }
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="@OpenConnectTenantDialog">
            Connect Tenant
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Refresh" OnClick="@LoadSubscriptions">
            Refresh
        </MudButton>
    </MudStack>
</MudPaper>

@* Subscription selection table *@
<MudTable T="TenantSubscription" Items="@_filteredSubscriptions" MultiSelection="true"
          SelectedItems="_selectedSubscriptions" SelectedItemsChanged="OnSelectedSubscriptionsChanged"
          Loading="@_loadingSubscriptions" Hover="true" Dense="true" Elevation="2">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Subscriptions</MudText>
        <MudSpacer />
        <MudTextField T="string" @bind-Value="_subSearchText" Placeholder="Search subscriptions..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium" Immediate="true" Class="mr-4" Style="max-width: 300px;" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Search"
                   OnClick="@ScanForRecommendations">
            Scan (@_selectedSubscriptions.Count selected)
        </MudButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Tenant</MudTh>
        <MudTh>Name</MudTh>
        <MudTh>Subscription ID</MudTh>
        <MudTh>State</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Tenant">
            <MudText Typo="Typo.body2"><strong>@context.TenantDisplayName</strong></MudText>
            <MudText Typo="Typo.caption" Style="font-family: monospace;">@context.TenantId</MudText>
        </MudTd>
        <MudTd DataLabel="Name">@context.DisplayName</MudTd>
        <MudTd DataLabel="Subscription ID">
            <MudText Typo="Typo.body2" Style="font-family: monospace;">@context.SubscriptionId</MudText>
        </MudTd>
        <MudTd DataLabel="State">
            <MudChip T="string" Color="@GetStateColor(context.State)" Size="Size.Small">
                @context.State
            </MudChip>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        @if (_loadError is not null)
        {
            <MudText Color="Color.Error">@_loadError</MudText>
        }
        else
        {
            <MudText>No subscriptions found.</MudText>
        }
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Loading subscriptions...</MudText>
    </LoadingContent>
</MudTable>

@* Summary chips — severity *@
@if (_recommendations.Count > 0)
{
    <MudPaper Class="pa-3 mt-4 mb-2" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
            <MudText Typo="Typo.body1" Class="mr-2"><b>@_recommendations.Count</b> unhealthy recommendations found</MudText>

            @* Severity chips *@
            @foreach (var group in _severityCounts)
            {
                <MudChip T="string" Color="@GetSeverityColor(group.Key)" Size="Size.Small"
                         Variant="@(_activeSeverity == group.Key ? Variant.Filled : Variant.Outlined)"
                         OnClick="@(() => ToggleSeverityFilter(group.Key))">
                    @group.Key (@group.Value)
                </MudChip>
            }

            <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />

            @* Category chips *@
            @foreach (var group in _categoryCounts)
            {
                <MudChip T="string" Color="@GetCategoryColor(group.Key)" Size="Size.Small"
                         Variant="@(_activeCategory == group.Key ? Variant.Filled : Variant.Outlined)"
                         OnClick="@(() => ToggleCategoryFilter(group.Key))">
                    @group.Key (@group.Value)
                </MudChip>
            }

            @if (_activeSeverity is not null || _activeCategory is not null)
            {
                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Default"
                           OnClick="@ClearFilters">
                    Clear Filters
                </MudButton>
            }
        </MudStack>
    </MudPaper>
}

@* Results table *@
@if (_scanComplete)
{
    <MudTable T="SecurityRecommendation" Items="@_filteredResults" Hover="true" Dense="true" Elevation="2" Class="mt-4">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Scan Results</MudText>
            <MudSpacer />
            <MudTextField T="string" @bind-Value="_resultSearchText" Placeholder="Search results..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Immediate="true" Style="max-width: 300px;" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel T="SecurityRecommendation" SortBy="@(new Func<SecurityRecommendation, object>(x => x.Severity))">Severity</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="SecurityRecommendation" SortBy="@(new Func<SecurityRecommendation, object>(x => x.Category))">Category</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="SecurityRecommendation" SortBy="@(new Func<SecurityRecommendation, object>(x => x.RecommendationName))">Recommendation</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="SecurityRecommendation" SortBy="@(new Func<SecurityRecommendation, object>(x => x.ResourceName))">Resource</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="SecurityRecommendation" SortBy="@(new Func<SecurityRecommendation, object>(x => x.ResourceGroup))">Resource Group</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="SecurityRecommendation" SortBy="@(new Func<SecurityRecommendation, object>(x => x.SubscriptionName))">Subscription</MudTableSortLabel></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Severity">
                <MudChip T="string" Color="@GetSeverityColor(context.Severity)" Size="Size.Small">
                    @context.Severity
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Category">
                <MudChip T="string" Color="@GetCategoryColor(context.Category)" Size="Size.Small">
                    @context.Category
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Recommendation">
                <MudText Typo="Typo.body2">@context.RecommendationName</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="description-html">@((MarkupString)context.Description)</MudText>
            </MudTd>
            <MudTd DataLabel="Resource">
                <MudText Typo="Typo.body2">@context.ResourceName</MudText>
                <MudText Typo="Typo.caption" Style="font-family: monospace;">@context.ResourceType</MudText>
            </MudTd>
            <MudTd DataLabel="Resource Group">@context.ResourceGroup</MudTd>
            <MudTd DataLabel="Subscription">@context.SubscriptionName</MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No unhealthy security recommendations found — looking good!</MudText>
        </NoRecordsContent>
    </MudTable>
}

@if (_scanning)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-4" />
    <MudText Typo="Typo.body2" Class="mt-2" Align="Align.Center">Scanning for security recommendations...</MudText>
}

@code {
    private List<TenantSubscription> _subscriptions = [];
    private HashSet<TenantSubscription> _selectedSubscriptions = [];
    private List<SecurityRecommendation> _recommendations = [];
    private bool _loadingSubscriptions = true;
    private bool _scanning;
    private bool _scanComplete;
    private string? _loadError;
    private string _subSearchText = string.Empty;
    private string _resultSearchText = string.Empty;
    private string? _activeSeverity;
    private string? _activeCategory;
    private string? _homeTenantId;
    private string? _homeTenantDisplayName;

    private IEnumerable<TenantSubscription> _filteredSubscriptions =>
        string.IsNullOrWhiteSpace(_subSearchText)
            ? _subscriptions
            : _subscriptions.Where(s =>
                s.DisplayName.Contains(_subSearchText, StringComparison.OrdinalIgnoreCase) ||
                s.SubscriptionId.Contains(_subSearchText, StringComparison.OrdinalIgnoreCase) ||
                (s.TenantDisplayName?.Contains(_subSearchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                s.TenantId.Contains(_subSearchText, StringComparison.OrdinalIgnoreCase));

    private Dictionary<string, int> _severityCounts =>
        _recommendations
            .GroupBy(r => r.Severity)
            .OrderByDescending(g => g.Key == "High" ? 3 : g.Key == "Medium" ? 2 : 1)
            .ToDictionary(g => g.Key, g => g.Count());

    private Dictionary<string, int> _categoryCounts =>
        _recommendations
            .GroupBy(r => r.Category)
            .OrderByDescending(g => g.Count())
            .ToDictionary(g => g.Key, g => g.Count());

    private IEnumerable<SecurityRecommendation> _filteredResults
    {
        get
        {
            var results = _recommendations.AsEnumerable();

            if (_activeSeverity is not null)
                results = results.Where(r => r.Severity == _activeSeverity);

            if (_activeCategory is not null)
                results = results.Where(r => r.Category == _activeCategory);

            if (!string.IsNullOrWhiteSpace(_resultSearchText))
            {
                results = results.Where(r =>
                    r.RecommendationName.Contains(_resultSearchText, StringComparison.OrdinalIgnoreCase) ||
                    r.ResourceName.Contains(_resultSearchText, StringComparison.OrdinalIgnoreCase) ||
                    r.ResourceGroup.Contains(_resultSearchText, StringComparison.OrdinalIgnoreCase) ||
                    r.SubscriptionName.Contains(_resultSearchText, StringComparison.OrdinalIgnoreCase) ||
                    r.Category.Contains(_resultSearchText, StringComparison.OrdinalIgnoreCase) ||
                    r.Severity.Contains(_resultSearchText, StringComparison.OrdinalIgnoreCase) ||
                    r.Description.Contains(_resultSearchText, StringComparison.OrdinalIgnoreCase));
            }

            return results;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        (_homeTenantId, _homeTenantDisplayName) = await TenantClientManager.GetHomeTenantInfoAsync();
        await LoadSubscriptions();
    }

    private async Task LoadSubscriptions()
    {
        _loadingSubscriptions = true;
        _loadError = null;
        _selectedSubscriptions.Clear();
        StateHasChanged();

        try
        {
            _subscriptions = (await SubscriptionService.GetSubscriptionsAsync()).ToList();
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load subscriptions: {ex.Message}";
        }
        finally
        {
            _loadingSubscriptions = false;
        }
    }

    private async Task OpenConnectTenantDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<FinOps.Components.Dialogs.ConnectTenantDialog>("Connect Tenant", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string tenantId })
        {
            Snackbar.Add($"Connected to tenant {tenantId}", Severity.Success);
            await LoadSubscriptions();
        }
    }

    private async Task DisconnectTenant(string tenantId)
    {
        TenantClientManager.DisconnectTenant(tenantId);
        Snackbar.Add($"Disconnected from tenant {tenantId}", Severity.Info);
        await LoadSubscriptions();
    }

    private void OnSelectedSubscriptionsChanged(HashSet<TenantSubscription> selected)
    {
        _selectedSubscriptions = selected;
    }

    private async Task ScanForRecommendations()
    {
        if (_selectedSubscriptions.Count == 0)
        {
            Snackbar.Add("Please select at least one subscription to scan.", Severity.Warning);
            return;
        }

        _scanning = true;
        _scanComplete = false;
        _recommendations.Clear();
        _activeSeverity = null;
        _activeCategory = null;
        StateHasChanged();

        try
        {
            var results = await SecurityRecommendationService.GetSecurityRecommendationsAsync(_selectedSubscriptions);
            _recommendations = results.ToList();
            _scanComplete = true;

            if (_recommendations.Count == 0)
            {
                Snackbar.Add("No unhealthy security recommendations found!", Severity.Success);
            }
            else
            {
                Snackbar.Add($"Found {_recommendations.Count} unhealthy recommendation(s)", Severity.Info);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Scan failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _scanning = false;
            StateHasChanged();
        }
    }

    private void ToggleSeverityFilter(string severity)
    {
        _activeSeverity = _activeSeverity == severity ? null : severity;
    }

    private void ToggleCategoryFilter(string category)
    {
        _activeCategory = _activeCategory == category ? null : category;
    }

    private void ClearFilters()
    {
        _activeSeverity = null;
        _activeCategory = null;
    }

    private static Color GetStateColor(string? state) => state switch
    {
        "Enabled" => Color.Success,
        "Disabled" => Color.Error,
        "Warned" => Color.Warning,
        _ => Color.Default
    };

    private static Color GetSeverityColor(string severity) => severity switch
    {
        "High" => Color.Error,
        "Medium" => Color.Warning,
        "Low" => Color.Info,
        _ => Color.Default
    };

    private static Color GetCategoryColor(string category) => category switch
    {
        "Compute" => Color.Error,
        "Networking" => Color.Warning,
        "Data" => Color.Info,
        "IdentityAndAccess" => Color.Secondary,
        "IoT" => Color.Tertiary,
        _ => Color.Default
    };
}
