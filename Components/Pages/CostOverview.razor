@page "/costs/overview"
@using FinOps.Models
@using FinOps.Services
@using FinOps.Components.Dialogs
@using System.Globalization
@using ApexCharts
@inject IAzureSubscriptionService SubscriptionService
@inject ICostAnalysisService CostAnalysisService
@inject TenantClientManager TenantClientManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<CostOverview> Logger

<PageTitle>Cost Overview</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Cost Overview</MudText>

<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
        @if (!string.IsNullOrEmpty(_homeTenantDisplayName))
        {
            <MudChip T="string" Color="MudBlazor.Color.Primary" Size="MudBlazor.Size.Small" Variant="Variant.Outlined">
                @_homeTenantDisplayName
            </MudChip>
        }
        @foreach (var tenantId in TenantClientManager.ConnectedTenantIds)
        {
            <MudChip T="string" Color="MudBlazor.Color.Secondary" Size="MudBlazor.Size.Small" OnClose="@(async _ => await DisconnectTenant(tenantId))">
                @tenantId
            </MudChip>
        }
        <MudButton Variant="Variant.Outlined" Color="MudBlazor.Color.Secondary" Size="MudBlazor.Size.Small"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="@OpenConnectTenantDialog">
            Connect Tenant
        </MudButton>
    </MudStack>
</MudPaper>

<MudTable T="SubscriptionCostInfo" Items="@_filteredSubscriptions" MultiSelection="true"
          SelectedItems="_selectedSubscriptions" SelectedItemsChanged="OnSelectedSubscriptionsChanged"
          Loading="@_loading" Hover="true" Dense="true" Elevation="2">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Subscriptions</MudText>
        <MudSpacer />
        <MudTextField T="string" @bind-Value="_searchText" Placeholder="Search subscriptions..." Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="MudBlazor.Size.Medium"
                      Immediate="true" Class="mr-4" Style="max-width: 300px;" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Tenant</MudTh>
        <MudTh>Name</MudTh>
        <MudTh>Subscription ID</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Tenant">
            <MudText Typo="Typo.body2"><strong>@context.Subscription.TenantDisplayName</strong></MudText>
            <MudText Typo="Typo.caption" Style="font-family: monospace;">@context.Subscription.TenantId</MudText>
        </MudTd>
        <MudTd DataLabel="Name">@context.Subscription.DisplayName</MudTd>
        <MudTd DataLabel="Subscription ID">
            <MudText Typo="Typo.body2" Style="font-family: monospace;">@context.Subscription.SubscriptionId</MudText>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        @if (_loadError is not null)
        {
            <MudText Color="MudBlazor.Color.Error">@_loadError</MudText>
        }
        else
        {
            <MudText>No subscriptions found.</MudText>
        }
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Loading subscriptions...</MudText>
    </LoadingContent>
</MudTable>

@if (_selectedSubscriptions.Count > 0)
{
    <MudPaper Class="pa-4 mt-4" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-4">
            Cost Analysis - @_selectedSubscriptions.Count Subscription@(_selectedSubscriptions.Count > 1 ? "s" : "") Selected
        </MudText>
        <MudText Typo="Typo.h5" Class="mb-4">Total Last 30 Days: @FormatCurrency(_totalCost)</MudText>

        @if (_loadingCharts)
        {
            <MudPaper Class="pa-8" Elevation="0" Style="text-align: center;">
                <MudProgressCircular Color="MudBlazor.Color.Primary" Size="MudBlazor.Size.Large" Indeterminate="true" />
                <MudText Typo="Typo.body1" Class="mt-4">Loading chart data...</MudText>
            </MudPaper>
        }
        else if (_actualCostPoints.Count == 0 && _forecastCostPoints.Count == 0)
        {
            <MudPaper Class="pa-8" Elevation="0" Style="text-align: center;">
                <MudText Typo="Typo.body1" Color="MudBlazor.Color.Secondary">
                    No cost data available for the selected period
                </MudText>
            </MudPaper>
        }
        else
        {
            <!-- Top Row: Service Breakdown (left) + Daily Trend (right) -->
            <MudGrid Spacing="3">
                <!-- Service Breakdown Donut Chart -->
                @if (_serviceBreakdown.Count > 0)
                {
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-4" Elevation="1">
                            <MudText Typo="Typo.h6" Class="mb-3">Top Services</MudText>
                            <ApexChart TItem="CostBreakdownItem"
                                       Title="Cost by Service"
                                       Options="@_donutChartOptions">
                                <ApexPointSeries TItem="CostBreakdownItem"
                                                 Items="_serviceBreakdown"
                                                 Name="Cost"
                                                 SeriesType="SeriesType.Donut"
                                                 XValue="@(e => e.Name)"
                                                 YAggregate="@(e => e.Sum(x => x.Cost))" />
                            </ApexChart>
                        </MudPaper>
                    </MudItem>
                }

                <!-- Daily Cost Trend with Forecast -->
                <MudItem xs="12" md="@(_serviceBreakdown.Count > 0 ? 8 : 12)">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudText Typo="Typo.h6" Class="mb-3">Daily Cost Trend</MudText>
                        <ApexChart TItem="ChartDataPoint"
                                   Title="30-Day Cost Trend"
                                   Options="@_trendChartOptions"
                                   Height="350">
                            <ApexPointSeries TItem="ChartDataPoint"
                                             Items="_actualCostPoints"
                                             Name="Actual Cost"
                                             SeriesType="SeriesType.Area"
                                             XValue="@(e => e.Date)"
                                             YAggregate="@(e => e.Sum(x => x.Value))"
                                             OrderBy="e => e.X" />
                            @if (_forecastCostPoints.Count > 0)
                            {
                                <ApexPointSeries TItem="ChartDataPoint"
                                                 Items="_forecastCostPoints"
                                                 Name="Forecast"
                                                 SeriesType="SeriesType.Line"
                                                 XValue="@(e => e.Date)"
                                                 YAggregate="@(e => e.Sum(x => x.Value))"
                                                 OrderBy="e => e.X" />
                            }
                        </ApexChart>
                    </MudPaper>
                </MudItem>

                <!-- Resource Group Breakdown Bar Chart -->
                @if (_resourceGroupBreakdown.Count > 0)
                {
                    <MudItem xs="12">
                        <MudPaper Class="pa-4" Elevation="1">
                            <MudText Typo="Typo.h6" Class="mb-3">Top Resource Groups</MudText>
                            <ApexChart TItem="CostBreakdownItem"
                                       Title="Cost by Resource Group"
                                       Options="@_barChartOptions"
                                       Height="300">
                                <ApexPointSeries TItem="CostBreakdownItem"
                                                 Items="_resourceGroupBreakdown"
                                                 Name="Cost"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="@(e => e.Name)"
                                                 YAggregate="@(e => e.Sum(x => x.Cost))"
                                                 OrderByDescending="e => e.Y" />
                            </ApexChart>
                        </MudPaper>
                    </MudItem>
                }

                <!-- Multi-Subscription Comparison (only if multiple subscriptions selected) -->
                @if (_selectedSubscriptions.Count > 1 && _subscriptionDailyCosts.Count > 1)
                {
                    <MudItem xs="12">
                        <MudPaper Class="pa-4" Elevation="1">
                            <MudText Typo="Typo.h6" Class="mb-3">Multi-Subscription Comparison</MudText>
                            <ApexChart TItem="CostDataPoint"
                                       Title="Daily Costs by Subscription"
                                       Options="@_stackedBarChartOptions"
                                       Height="350">
                                @foreach (var kvp in _subscriptionDailyCosts)
                                {
                                    <ApexPointSeries TItem="CostDataPoint"
                                                     Items="kvp.Value"
                                                     Name="@kvp.Key"
                                                     SeriesType="SeriesType.Bar"
                                                     XValue="@(e => e.Date)"
                                                     YAggregate="@(e => e.Sum(x => x.Cost))"
                                                     OrderBy="e => e.X" />
                                }
                            </ApexChart>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudPaper>
}

@code {
    private List<TenantSubscription> _subscriptions = [];
    private List<SubscriptionCostInfo> _subscriptionCostInfo = [];
    private HashSet<SubscriptionCostInfo> _selectedSubscriptions = [];
    private bool _loading = true;
    private string? _loadError;
    private string _searchText = string.Empty;
    private string? _homeTenantId;
    private string? _homeTenantDisplayName;
    private decimal _totalCost = 0m;

    // Chart data fields
    private bool _loadingCharts = false;
    private List<ChartDataPoint> _actualCostPoints = new();
    private List<ChartDataPoint> _forecastCostPoints = new();
    private List<CostBreakdownItem> _serviceBreakdown = new();
    private List<CostBreakdownItem> _resourceGroupBreakdown = new();
    private Dictionary<string, List<CostDataPoint>> _subscriptionDailyCosts = new();
    private DateTime _thirtyDaysAgo;

    // Chart options
    private ApexChartOptions<ChartDataPoint> _trendChartOptions = new();
    private ApexChartOptions<CostBreakdownItem> _donutChartOptions = new();
    private ApexChartOptions<CostBreakdownItem> _barChartOptions = new();
    private ApexChartOptions<CostDataPoint> _stackedBarChartOptions = new();

    private IEnumerable<SubscriptionCostInfo> _filteredSubscriptions =>
        string.IsNullOrWhiteSpace(_searchText)
            ? _subscriptionCostInfo
            : _subscriptionCostInfo.Where(s =>
                s.Subscription.DisplayName.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                s.Subscription.SubscriptionId.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                (s.Subscription.TenantDisplayName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                s.Subscription.TenantId.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        (_homeTenantId, _homeTenantDisplayName) = await TenantClientManager.GetHomeTenantInfoAsync();
        InitializeChartOptions();
        await LoadSubscriptions();
    }

    private void InitializeChartOptions()
    {
        // Trend chart options (Area + Line combination)
        _trendChartOptions = new ApexChartOptions<ChartDataPoint>
        {
            Theme = new Theme { Mode = Mode.Light },
            Chart = new Chart
            {
                Toolbar = new Toolbar { Show = true },
                Zoom = new Zoom { Enabled = true }
            },
            Stroke = new Stroke { Curve = Curve.Smooth, Width = 2 },
            Xaxis = new XAxis
            {
                Type = XAxisType.Datetime,
                Labels = new XAxisLabels { Format = "dd MMM" }
            },
            Yaxis = new List<YAxis>
            {
                new YAxis
                {
                    Labels = new YAxisLabels
                    {
                        Formatter = "function(val) { return '$' + val.toFixed(2); }"
                    }
                }
            },
            Colors = new List<string> { "#2196F3", "#FF9800" },
            Legend = new Legend { Position = LegendPosition.Top }
        };

        // Donut chart options
        _donutChartOptions = new ApexChartOptions<CostBreakdownItem>
        {
            Theme = new Theme { Mode = Mode.Light },
            Chart = new Chart { Height = 350 },
            Legend = new Legend { Position = LegendPosition.Bottom },
            DataLabels = new DataLabels
            {
                Enabled = true,
                Formatter = "function(val) { return val.toFixed(1) + '%'; }"
            }
        };

        // Horizontal bar chart options
        _barChartOptions = new ApexChartOptions<CostBreakdownItem>
        {
            Theme = new Theme { Mode = Mode.Light },
            Chart = new Chart { Height = 300 },
            PlotOptions = new PlotOptions
            {
                Bar = new PlotOptionsBar
                {
                    Horizontal = true
                }
            },
            DataLabels = new DataLabels
            {
                Enabled = true,
                Formatter = "function(val) { return '$' + val.toFixed(2); }"
            },
            Xaxis = new XAxis
            {
                Labels = new XAxisLabels
                {
                    Formatter = "function(val) { return '$' + val.toFixed(2); }"
                }
            },
            Colors = new List<string> { "#4CAF50" }
        };

        // Stacked bar chart options
        _stackedBarChartOptions = new ApexChartOptions<CostDataPoint>
        {
            Theme = new Theme { Mode = Mode.Light },
            Chart = new Chart
            {
                Stacked = true,
                Toolbar = new Toolbar { Show = true }
            },
            PlotOptions = new PlotOptions
            {
                Bar = new PlotOptionsBar
                {
                    Horizontal = false
                }
            },
            Xaxis = new XAxis
            {
                Type = XAxisType.Datetime,
                Labels = new XAxisLabels { Format = "dd MMM" }
            },
            Yaxis = new List<YAxis>
            {
                new YAxis
                {
                    Labels = new YAxisLabels
                    {
                        Formatter = "function(val) { return '$' + val.toFixed(2); }"
                    }
                }
            },
            Legend = new Legend { Position = LegendPosition.Top }
        };
    }

    private async Task LoadSubscriptions()
    {
        _loading = true;
        _loadError = null;
        StateHasChanged();

        try
        {
            _subscriptions = (await SubscriptionService.GetSubscriptionsAsync()).ToList();
            _subscriptionCostInfo = _subscriptions.Select(s => new SubscriptionCostInfo
            {
                Subscription = s
            }).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load subscriptions");
            _loadError = "Failed to load subscriptions.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSelectedSubscriptionsChanged(HashSet<SubscriptionCostInfo> selected)
    {
        _selectedSubscriptions = selected;
        await CalculateTotalCost();
        await LoadChartDataAsync();
    }

    private async Task CalculateTotalCost()
    {
        if (_selectedSubscriptions.Count == 0)
        {
            _totalCost = 0m;
            return;
        }

        try
        {
            var now = DateTime.UtcNow;
            var thirtyDaysAgo = now.AddDays(-30);

            var tasks = _selectedSubscriptions.Select(async info =>
            {
                try
                {
                    var result = await CostAnalysisService.GetCostsAsync(
                        info.Subscription.SubscriptionId,
                        info.Subscription.TenantId,
                        thirtyDaysAgo,
                        now);
                    return result.TotalCost;
                }
                catch
                {
                    return 0m;
                }
            });

            var results = await Task.WhenAll(tasks);
            _totalCost = results.Sum();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to calculate total cost");
            Snackbar.Add("Failed to calculate total.", Severity.Error);
        }
    }

    private async Task OpenConnectTenantDialog()
    {
        var dialog = await DialogService.ShowAsync<ConnectTenantDialog>("Connect Tenant");
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string tenantId })
        {
            TenantClientManager.ConnectTenant(tenantId);
            Snackbar.Add($"Connected to tenant: {tenantId}", Severity.Success);
            await LoadSubscriptions();
        }
    }

    private async Task DisconnectTenant(string tenantId)
    {
        TenantClientManager.DisconnectTenant(tenantId);
        Snackbar.Add($"Disconnected from tenant: {tenantId}", Severity.Info);
        await LoadSubscriptions();
    }

    private static string FormatCurrency(decimal amount)
    {
        return amount.ToString("C2", CultureInfo.CreateSpecificCulture("en-US"));
    }

    private async Task LoadChartDataAsync()
    {
        if (_selectedSubscriptions.Count == 0)
        {
            _actualCostPoints.Clear();
            _forecastCostPoints.Clear();
            _serviceBreakdown.Clear();
            _resourceGroupBreakdown.Clear();
            _subscriptionDailyCosts.Clear();
            return;
        }

        _loadingCharts = true;
        StateHasChanged();

        try
        {
            var now = DateTime.UtcNow;
            _thirtyDaysAgo = now.AddDays(-30);

            // Batch 1: Get costs for all selected subscriptions (parallel)
            var costTasks = _selectedSubscriptions.Select(async info =>
            {
                try
                {
                    var result = await CostAnalysisService.GetCostsAsync(
                        info.Subscription.SubscriptionId,
                        info.Subscription.TenantId,
                        _thirtyDaysAgo,
                        now);
                    return (info.Subscription.SubscriptionId, info.Subscription.DisplayName, (CostQueryResult?)result);
                }
                catch
                {
                    return (info.Subscription.SubscriptionId, info.Subscription.DisplayName, (CostQueryResult?)null);
                }
            }).ToList();

            var costResults = await Task.WhenAll(costTasks);

            // Aggregate costs by date for trend chart
            var dailyCostsDict = new Dictionary<DateTime, decimal>();
            _subscriptionDailyCosts.Clear();

            foreach (var (subId, subName, result) in costResults)
            {
                if (result != null)
                {
                    // Store per-subscription data for multi-subscription comparison
                    _subscriptionDailyCosts[subName] = result.Data.ToList();

                    // Aggregate across all subscriptions
                    foreach (var point in result.Data)
                    {
                        if (dailyCostsDict.ContainsKey(point.Date))
                            dailyCostsDict[point.Date] += point.Cost;
                        else
                            dailyCostsDict[point.Date] = point.Cost;
                    }
                }
            }

            _actualCostPoints = dailyCostsDict
                .OrderBy(kvp => kvp.Key)
                .Select(kvp => new ChartDataPoint { Date = kvp.Key, Value = kvp.Value })
                .ToList();

            // Small delay to avoid rate limiting
            await Task.Delay(800);

            // Batch 2: Get forecast for first subscription
            if (_selectedSubscriptions.Count > 0)
            {
                var firstSub = _selectedSubscriptions.First();
                try
                {
                    var monthEnd = new DateTime(now.Year, now.Month, 1, 0, 0, 0, DateTimeKind.Utc)
                        .AddMonths(1).AddDays(-1);
                    var forecastResult = await CostAnalysisService.GetCostForecastAsync(
                        firstSub.Subscription.SubscriptionId,
                        firstSub.Subscription.TenantId,
                        now,
                        monthEnd);

                    _forecastCostPoints = forecastResult.Data
                        .Where(p => p.ForecastedCost.HasValue)
                        .Select(p => new ChartDataPoint { Date = p.Date, Value = p.ForecastedCost!.Value })
                        .ToList();
                }
                catch
                {
                    _forecastCostPoints.Clear();
                }
            }

            // Small delay to avoid rate limiting
            await Task.Delay(800);

            // Batch 3: Get service breakdown for first subscription
            if (_selectedSubscriptions.Count > 0)
            {
                var firstSub = _selectedSubscriptions.First();
                try
                {
                    _serviceBreakdown = (await CostAnalysisService.GetCostsByDimensionAsync(
                        firstSub.Subscription.SubscriptionId,
                        firstSub.Subscription.TenantId,
                        _thirtyDaysAgo,
                        now,
                        "ServiceName",
                        8)).ToList();
                }
                catch
                {
                    _serviceBreakdown.Clear();
                }
            }

            // Small delay to avoid rate limiting
            await Task.Delay(800);

            // Batch 4: Get resource group breakdown for first subscription
            if (_selectedSubscriptions.Count > 0)
            {
                var firstSub = _selectedSubscriptions.First();
                try
                {
                    _resourceGroupBreakdown = (await CostAnalysisService.GetCostsByDimensionAsync(
                        firstSub.Subscription.SubscriptionId,
                        firstSub.Subscription.TenantId,
                        _thirtyDaysAgo,
                        now,
                        "ResourceGroup",
                        10)).ToList();
                }
                catch
                {
                    _resourceGroupBreakdown.Clear();
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load chart data");
            Snackbar.Add("Failed to load chart data.", Severity.Error);
        }
        finally
        {
            _loadingCharts = false;
            StateHasChanged();
        }
    }

    private class ChartDataPoint
    {
        public DateTime Date { get; set; }
        public decimal Value { get; set; }
    }

    private class SubscriptionCostInfo
    {
        public required TenantSubscription Subscription { get; init; }
    }
}
