@page "/budgets/resource-groups"
@using FinOps.Models
@using FinOps.Services
@inject IAzureSubscriptionService SubscriptionService
@inject IBudgetService BudgetService
@inject IResourceTaggingService TaggingService
@inject TenantClientManager TenantClientManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Resource Group Budgets</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Resource Group Budgets</MudText>

@* Tenant connection bar *@
<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
        @if (!string.IsNullOrEmpty(_homeTenantDisplayName))
        {
            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">
                @_homeTenantDisplayName
            </MudChip>
        }
        @foreach (var tenantId in TenantClientManager.ConnectedTenantIds)
        {
            <MudChip T="string" Color="Color.Secondary" Size="Size.Small" OnClose="@(async _ => await DisconnectTenant(tenantId))">
                @tenantId
            </MudChip>
        }
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="@OpenConnectTenantDialog">
            Connect Tenant
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Refresh" OnClick="@LoadSubscriptions">
            Refresh
        </MudButton>
    </MudStack>
</MudPaper>

@* Step 1: Select a subscription *@
<MudTable T="TenantSubscription" Items="@_filteredSubscriptions" Loading="@_loadingSubscriptions"
          Hover="true" Dense="true" Elevation="2" MultiSelection="true"
          SelectedItems="@_selectedSubscriptions" SelectedItemsChanged="OnSubscriptionSelectionChanged">
    <ToolBarContent>
        <MudText Typo="Typo.h6">1. Select a Subscription</MudText>
        <MudSpacer />
        <MudTextField T="string" @bind-Value="_searchText" Placeholder="Search subscriptions..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium" Immediate="true" Class="mr-4" Style="max-width: 300px;" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Tenant</MudTh>
        <MudTh><MudTableSortLabel T="TenantSubscription" SortBy="@(new Func<TenantSubscription, object>(x => x.DisplayName))">Name</MudTableSortLabel></MudTh>
        <MudTh>Subscription ID</MudTh>
        <MudTh>State</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Tenant">
            <MudText Typo="Typo.body2"><strong>@context.TenantDisplayName</strong></MudText>
            <MudText Typo="Typo.caption" Style="font-family: monospace;">@context.TenantId</MudText>
        </MudTd>
        <MudTd DataLabel="Name">@context.DisplayName</MudTd>
        <MudTd DataLabel="Subscription ID">
            <MudText Typo="Typo.body2" Style="font-family: monospace;">@context.SubscriptionId</MudText>
        </MudTd>
        <MudTd DataLabel="State">
            <MudChip T="string" Color="@GetStateColor(context.State)" Size="Size.Small">
                @context.State
            </MudChip>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        @if (_loadError is not null)
        {
            <MudText Color="Color.Error">@_loadError</MudText>
        }
        else
        {
            <MudText>No subscriptions found.</MudText>
        }
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Loading subscriptions...</MudText>
    </LoadingContent>
</MudTable>

@* Step 2: Select resource groups *@
@if (_selectedSubscription is not null)
{
    <MudTable T="ResourceGroupInfo" Items="@_resourceGroups" MultiSelection="true"
              @bind-SelectedItems="_selectedResourceGroups" Loading="@_loadingResourceGroups"
              Hover="true" Dense="true" Elevation="2" Class="mt-4">
        <ToolBarContent>
            <MudText Typo="Typo.h6">2. Select Resource Groups</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@OpenCreateBudgetDialog">
                Create Budget (@_selectedResourceGroups.Count selected)
            </MudButton>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel T="ResourceGroupInfo" SortBy="@(new Func<ResourceGroupInfo, object>(x => x.Name))">Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="ResourceGroupInfo" SortBy="@(new Func<ResourceGroupInfo, object>(x => x.Location ?? ""))">Location</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="ResourceGroupInfo" SortBy="@(new Func<ResourceGroupInfo, object>(x => x.ProvisioningState ?? ""))">State</MudTableSortLabel></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Location">@context.Location</MudTd>
            <MudTd DataLabel="State">@context.ProvisioningState</MudTd>
        </RowTemplate>
        <NoRecordsContent>
            @if (_rgLoadError is not null)
            {
                <MudText Color="Color.Error">@_rgLoadError</MudText>
            }
            else
            {
                <MudText>No resource groups found.</MudText>
            }
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Loading resource groups...</MudText>
        </LoadingContent>
    </MudTable>
}

@* Budget creation results *@
@if (_results.Count > 0)
{
    <MudText Typo="Typo.h6" Class="mt-4 mb-2">Budget Creation Results</MudText>
    <MudTable T="BudgetCreationResult" Items="@_results" Hover="true" Dense="true" Elevation="2">
        <HeaderContent>
            <MudTh>Subscription</MudTh>
            <MudTh>Resource Group</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Details</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Subscription">@context.SubscriptionName</MudTd>
            <MudTd DataLabel="Resource Group">@context.ResourceGroupName</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@(context.Success ? Color.Success : Color.Error)" Size="Size.Small">
                    @(context.Success ? "Success" : "Failed")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Details">
                @if (!context.Success)
                {
                    <MudText Typo="Typo.body2" Color="Color.Error">@context.ErrorMessage</MudText>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@* Existing budgets *@
@if (_selectedSubscription is not null && _selectedResourceGroups.Count > 0)
{
    <MudTable T="BudgetInfo" Items="@_existingBudgets" Loading="@_loadingBudgets"
              Hover="true" Dense="true" Elevation="2" Class="mt-4">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Existing Budgets</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="@LoadExistingBudgets">
                Refresh
            </MudButton>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Resource Group</MudTh>
            <MudTh><MudTableSortLabel T="BudgetInfo" SortBy="@(new Func<BudgetInfo, object>(x => x.Name))">Name</MudTableSortLabel></MudTh>
            <MudTh>Amount</MudTh>
            <MudTh>Current Spend</MudTh>
            <MudTh>Time Grain</MudTh>
            <MudTh>Start Date</MudTh>
            <MudTh>End Date</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Resource Group">@context.ResourceGroupName</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Amount">@(context.Amount?.ToString("C2"))</MudTd>
            <MudTd DataLabel="Current Spend">
                @if (context.CurrentSpend.HasValue && context.Amount.HasValue && context.Amount.Value > 0)
                {
                    var pct = context.CurrentSpend.Value / context.Amount.Value * 100;
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.body2">@context.CurrentSpend.Value.ToString("C2")</MudText>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(pct > 90 ? Color.Error : pct > 70 ? Color.Warning : Color.Success)">
                            @pct.ToString("F0")%
                        </MudChip>
                    </MudStack>
                }
                else
                {
                    <MudText Typo="Typo.body2">@(context.CurrentSpend?.ToString("C2") ?? "-")</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Time Grain">@context.TimeGrain</MudTd>
            <MudTd DataLabel="Start Date">@(context.StartDate?.ToString("dd MMM yyyy") ?? "-")</MudTd>
            <MudTd DataLabel="End Date">@(context.EndDate?.ToString("dd MMM yyyy") ?? "-")</MudTd>
            <MudTd DataLabel="Actions">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                               Size="Size.Small" OnClick="@(() => EditBudget(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                               Size="Size.Small" OnClick="@(() => DeleteBudget(context))" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No existing budgets found for the selected resource group(s).</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Loading budgets...</MudText>
        </LoadingContent>
    </MudTable>
}

@code {
    private List<TenantSubscription> _subscriptions = [];
    private HashSet<TenantSubscription> _selectedSubscriptions = [];
    private TenantSubscription? _selectedSubscription => _selectedSubscriptions.Count == 1 ? _selectedSubscriptions.First() : null;
    private List<ResourceGroupInfo> _resourceGroups = [];
    private HashSet<ResourceGroupInfo> _selectedResourceGroups = [];
    private List<BudgetCreationResult> _results = [];
    private List<BudgetInfo> _existingBudgets = [];
    private bool _loadingSubscriptions = true;
    private bool _loadingResourceGroups;
    private bool _loadingBudgets;
    private bool _creating;
    private string? _loadError;
    private string? _rgLoadError;
    private string _searchText = string.Empty;
    private string? _homeTenantId;
    private string? _homeTenantDisplayName;

    private IEnumerable<TenantSubscription> _filteredSubscriptions =>
        string.IsNullOrWhiteSpace(_searchText)
            ? _subscriptions
            : _subscriptions.Where(s =>
                s.DisplayName.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                s.SubscriptionId.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                (s.TenantDisplayName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                s.TenantId.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        (_homeTenantId, _homeTenantDisplayName) = await TenantClientManager.GetHomeTenantInfoAsync();
        await LoadSubscriptions();
    }

    private async Task LoadSubscriptions()
    {
        _loadingSubscriptions = true;
        _loadError = null;
        _selectedSubscriptions.Clear();
        _resourceGroups.Clear();
        _selectedResourceGroups.Clear();
        _existingBudgets.Clear();
        StateHasChanged();

        try
        {
            _subscriptions = (await SubscriptionService.GetSubscriptionsAsync()).ToList();
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load subscriptions: {ex.Message}";
        }
        finally
        {
            _loadingSubscriptions = false;
        }
    }

    private async Task OnSubscriptionSelectionChanged(HashSet<TenantSubscription> selected)
    {
        // Enforce single selection: keep only the newly added item
        if (selected.Count > 1)
        {
            var newItem = selected.Except(_selectedSubscriptions).FirstOrDefault();
            _selectedSubscriptions = newItem is not null ? [newItem] : [];
        }
        else
        {
            _selectedSubscriptions = selected;
        }

        _selectedResourceGroups.Clear();
        _existingBudgets.Clear();
        _results.Clear();

        var subscription = _selectedSubscription;
        if (subscription is null)
        {
            _resourceGroups.Clear();
            return;
        }

        _loadingResourceGroups = true;
        _rgLoadError = null;
        StateHasChanged();

        try
        {
            _resourceGroups = (await TaggingService.GetResourceGroupsAsync(subscription)).ToList();
        }
        catch (Exception ex)
        {
            _rgLoadError = $"Failed to load resource groups: {ex.Message}";
            _resourceGroups.Clear();
        }
        finally
        {
            _loadingResourceGroups = false;
        }
    }

    private async Task OpenConnectTenantDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<FinOps.Components.Dialogs.ConnectTenantDialog>("Connect Tenant", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string tenantId })
        {
            Snackbar.Add($"Connected to tenant {tenantId}", Severity.Success);
            await LoadSubscriptions();
        }
    }

    private async Task DisconnectTenant(string tenantId)
    {
        TenantClientManager.DisconnectTenant(tenantId);
        Snackbar.Add($"Disconnected from tenant {tenantId}", Severity.Info);
        await LoadSubscriptions();
    }

    private async Task OpenCreateBudgetDialog()
    {
        if (_creating) return;
        if (_selectedSubscription is null || _selectedResourceGroups.Count == 0)
        {
            Snackbar.Add("Select at least one resource group first.", Severity.Warning);
            return;
        }

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<FinOps.Components.Dialogs.CreateBudgetDialog>("Create Budget", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: BudgetFormModel form })
        {
            _creating = true;
            StateHasChanged();

            try
            {
                var creationResults = await BudgetService.CreateBudgetForResourceGroupsAsync(
                    _selectedSubscription, _selectedResourceGroups, form);
                _results = creationResults.ToList();

                var succeeded = _results.Count(r => r.Success);
                var failed = _results.Count(r => !r.Success);

                if (failed == 0)
                {
                    Snackbar.Add($"Budget created for all {succeeded} resource group(s)", Severity.Success);
                }
                else
                {
                    Snackbar.Add($"{succeeded} succeeded, {failed} failed", Severity.Warning);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error creating budget: {ex.Message}", Severity.Error);
            }
            finally
            {
                _creating = false;
                await LoadExistingBudgets();
            }
        }
    }

    private async Task LoadExistingBudgets()
    {
        if (_selectedSubscription is null || _selectedResourceGroups.Count == 0) return;

        _loadingBudgets = true;
        StateHasChanged();

        try
        {
            var allBudgets = new List<BudgetInfo>();
            foreach (var rg in _selectedResourceGroups)
            {
                var budgets = await BudgetService.GetBudgetsForResourceGroupAsync(_selectedSubscription, rg);
                allBudgets.AddRange(budgets);
            }
            _existingBudgets = allBudgets;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load budgets: {ex.Message}", Severity.Error);
            _existingBudgets.Clear();
        }
        finally
        {
            _loadingBudgets = false;
            StateHasChanged();
        }
    }

    private async Task EditBudget(BudgetInfo budget)
    {
        BudgetFormModel form;
        try
        {
            form = await BudgetService.GetBudgetFormDataAsync(budget);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load budget data: {ex.Message}", Severity.Error);
            return;
        }

        var parameters = new DialogParameters<FinOps.Components.Dialogs.CreateBudgetDialog>
        {
            { x => x.IsEditMode, true },
            { x => x.ExistingModel, form }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<FinOps.Components.Dialogs.CreateBudgetDialog>("Edit Budget", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: BudgetFormModel updatedForm })
        {
            try
            {
                await BudgetService.UpdateBudgetAsync(budget, updatedForm);
                Snackbar.Add($"Budget '{budget.Name}' updated", Severity.Success);
                await LoadExistingBudgets();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to update budget: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteBudget(BudgetInfo budget)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Delete Budget",
            $"Are you sure you want to delete budget '{budget.Name}' from resource group '{budget.ResourceGroupName}'?",
            yesText: "Delete", cancelText: "Cancel");

        if (confirm != true) return;

        try
        {
            await BudgetService.DeleteBudgetAsync(budget);
            Snackbar.Add($"Budget '{budget.Name}' deleted", Severity.Success);
            await LoadExistingBudgets();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to delete budget: {ex.Message}", Severity.Error);
        }
    }

    private static Color GetStateColor(string? state) => state switch
    {
        "Enabled" => Color.Success,
        "Disabled" => Color.Error,
        "Warned" => Color.Warning,
        _ => Color.Default
    };
}
