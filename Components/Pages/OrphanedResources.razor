@page "/orphaned-resources"
@using FinOps.Models
@using FinOps.Services
@inject IAzureSubscriptionService SubscriptionService
@inject IOrphanedResourceService OrphanedResourceService
@inject TenantClientManager TenantClientManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<OrphanedResources> Logger

<PageTitle>Orphaned Resources</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Orphaned Resources</MudText>

@* Tenant connection bar *@
<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
        @if (!string.IsNullOrEmpty(_homeTenantDisplayName))
        {
            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">
                @_homeTenantDisplayName
            </MudChip>
        }
        @foreach (var tenantId in TenantClientManager.ConnectedTenantIds)
        {
            <MudChip T="string" Color="Color.Secondary" Size="Size.Small" OnClose="@(async _ => await DisconnectTenant(tenantId))">
                @tenantId
            </MudChip>
        }
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="@OpenConnectTenantDialog">
            Connect Tenant
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Refresh" OnClick="@LoadSubscriptions">
            Refresh
        </MudButton>
    </MudStack>
</MudPaper>

@* Subscription selection table *@
<MudTable T="TenantSubscription" Items="@_filteredSubscriptions" MultiSelection="true"
          SelectedItems="_selectedSubscriptions" SelectedItemsChanged="OnSelectedSubscriptionsChanged"
          Loading="@_loadingSubscriptions" Hover="true" Dense="true" Elevation="2">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Subscriptions</MudText>
        <MudSpacer />
        <MudTextField T="string" @bind-Value="_subSearchText" Placeholder="Search subscriptions..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium" Immediate="true" Class="mr-4" Style="max-width: 300px;" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Search"
                   OnClick="@ScanForOrphanedResources">
            Scan (@_selectedSubscriptions.Count selected)
        </MudButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Tenant</MudTh>
        <MudTh>Name</MudTh>
        <MudTh>Subscription ID</MudTh>
        <MudTh>State</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Tenant">
            <MudText Typo="Typo.body2"><strong>@context.TenantDisplayName</strong></MudText>
            <MudText Typo="Typo.caption" Style="font-family: monospace;">@context.TenantId</MudText>
        </MudTd>
        <MudTd DataLabel="Name">
            <MudLink Href="@GetAzurePortalUrl(context)" Target="_blank" Typo="Typo.body2">
                @context.DisplayName
            </MudLink>
        </MudTd>
        <MudTd DataLabel="Subscription ID">
            <MudLink Href="@GetAzurePortalUrl(context)" Target="_blank" Typo="Typo.body2" Style="font-family: monospace;">
                @context.SubscriptionId
            </MudLink>
        </MudTd>
        <MudTd DataLabel="State">
            <MudChip T="string" Color="@GetStateColor(context.State)" Size="Size.Small">
                @context.State
            </MudChip>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        @if (_loadError is not null)
        {
            <MudText Color="Color.Error">@_loadError</MudText>
        }
        else
        {
            <MudText>No subscriptions found.</MudText>
        }
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Loading subscriptions...</MudText>
    </LoadingContent>
</MudTable>

@* Summary chips *@
@if (_orphanedResources.Count > 0)
{
    <MudPaper Class="pa-3 mt-4 mb-2" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
            <MudText Typo="Typo.body1" Class="mr-2"><b>@_orphanedResources.Count</b> orphaned resources found</MudText>
            @foreach (var group in _categoryCounts)
            {
                <MudChip T="string" Color="@GetCategoryColor(group.Key)" Size="Size.Small"
                         Variant="@(_activeCategory == group.Key ? Variant.Filled : Variant.Outlined)"
                         OnClick="@(() => ToggleCategoryFilter(group.Key))">
                    @group.Key (@group.Value)
                </MudChip>
            }
            @if (_activeCategory is not null)
            {
                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Default"
                           OnClick="@(() => _activeCategory = null)">
                    Clear Filter
                </MudButton>
            }
        </MudStack>
    </MudPaper>
}

@* Results table *@
@if (_scanComplete)
{
    <MudTable T="OrphanedResourceInfo" Items="@_filteredResults" Hover="true" Dense="true" Elevation="2" Class="mt-4">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Scan Results</MudText>
            <MudSpacer />
            <MudTextField T="string" @bind-Value="_resultSearchText" Placeholder="Search results..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Immediate="true" Style="max-width: 300px;" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel T="OrphanedResourceInfo" SortBy="@(new Func<OrphanedResourceInfo, object>(x => x.Category))">Category</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="OrphanedResourceInfo" SortBy="@(new Func<OrphanedResourceInfo, object>(x => x.Name))">Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="OrphanedResourceInfo" SortBy="@(new Func<OrphanedResourceInfo, object>(x => x.ResourceGroup))">Resource Group</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="OrphanedResourceInfo" SortBy="@(new Func<OrphanedResourceInfo, object>(x => x.SubscriptionName))">Subscription</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="OrphanedResourceInfo" SortBy="@(new Func<OrphanedResourceInfo, object>(x => x.Location))">Location</MudTableSortLabel></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Category">
                <MudChip T="string" Color="@GetCategoryColor(context.Category)" Size="Size.Small">
                    @context.Category
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Name">
                <MudLink Href="@GetResourcePortalUrl(context)" Target="_blank" Typo="Typo.body2">
                    @context.Name
                </MudLink>
            </MudTd>
            <MudTd DataLabel="Resource Group">
                <MudLink Href="@GetResourceGroupPortalUrl(context)" Target="_blank" Typo="Typo.body2">
                    @context.ResourceGroup
                </MudLink>
            </MudTd>
            <MudTd DataLabel="Subscription">
                <MudLink Href="@GetSubscriptionPortalUrl(context)" Target="_blank" Typo="Typo.body2">
                    @context.SubscriptionName
                </MudLink>
            </MudTd>
            <MudTd DataLabel="Location">@context.Location</MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No orphaned resources found — looking good!</MudText>
        </NoRecordsContent>
    </MudTable>
}

@if (_scanning)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-4" />
    <MudText Typo="Typo.body2" Class="mt-2" Align="Align.Center">Scanning for orphaned resources...</MudText>
}

@code {
    private List<TenantSubscription> _subscriptions = [];
    private HashSet<TenantSubscription> _selectedSubscriptions = [];
    private List<OrphanedResourceInfo> _orphanedResources = [];
    private bool _loadingSubscriptions = true;
    private bool _scanning;
    private bool _scanComplete;
    private string? _loadError;
    private string _subSearchText = string.Empty;
    private string _resultSearchText = string.Empty;
    private string? _activeCategory;
    private string? _homeTenantId;
    private string? _homeTenantDisplayName;

    private IEnumerable<TenantSubscription> _filteredSubscriptions =>
        string.IsNullOrWhiteSpace(_subSearchText)
            ? _subscriptions
            : _subscriptions.Where(s =>
                s.DisplayName.Contains(_subSearchText, StringComparison.OrdinalIgnoreCase) ||
                s.SubscriptionId.Contains(_subSearchText, StringComparison.OrdinalIgnoreCase) ||
                (s.TenantDisplayName?.Contains(_subSearchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                s.TenantId.Contains(_subSearchText, StringComparison.OrdinalIgnoreCase));

    private Dictionary<string, int> _categoryCounts =>
        _orphanedResources
            .GroupBy(r => r.Category)
            .OrderByDescending(g => g.Count())
            .ToDictionary(g => g.Key, g => g.Count());

    private IEnumerable<OrphanedResourceInfo> _filteredResults
    {
        get
        {
            var results = _activeCategory is not null
                ? _orphanedResources.Where(r => r.Category == _activeCategory)
                : _orphanedResources.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(_resultSearchText))
            {
                results = results.Where(r =>
                    r.Name.Contains(_resultSearchText, StringComparison.OrdinalIgnoreCase) ||
                    r.ResourceGroup.Contains(_resultSearchText, StringComparison.OrdinalIgnoreCase) ||
                    r.SubscriptionName.Contains(_resultSearchText, StringComparison.OrdinalIgnoreCase) ||
                    r.Location.Contains(_resultSearchText, StringComparison.OrdinalIgnoreCase) ||
                    r.Category.Contains(_resultSearchText, StringComparison.OrdinalIgnoreCase));
            }

            return results;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        (_homeTenantId, _homeTenantDisplayName) = await TenantClientManager.GetHomeTenantInfoAsync();
        await LoadSubscriptions();
    }

    private async Task LoadSubscriptions()
    {
        _loadingSubscriptions = true;
        _loadError = null;
        _selectedSubscriptions.Clear();
        StateHasChanged();

        try
        {
            _subscriptions = (await SubscriptionService.GetSubscriptionsAsync()).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load subscriptions");
            _loadError = "Failed to load subscriptions.";
        }
        finally
        {
            _loadingSubscriptions = false;
        }
    }

    private async Task OpenConnectTenantDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<FinOps.Components.Dialogs.ConnectTenantDialog>("Connect Tenant", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string tenantId })
        {
            Snackbar.Add($"Connected to tenant {tenantId}", Severity.Success);
            await LoadSubscriptions();
        }
    }

    private async Task DisconnectTenant(string tenantId)
    {
        TenantClientManager.DisconnectTenant(tenantId);
        Snackbar.Add($"Disconnected from tenant {tenantId}", Severity.Info);
        await LoadSubscriptions();
    }

    private void OnSelectedSubscriptionsChanged(HashSet<TenantSubscription> selected)
    {
        _selectedSubscriptions = selected;
    }

    private async Task ScanForOrphanedResources()
    {
        if (_selectedSubscriptions.Count == 0)
        {
            Snackbar.Add("Please select at least one subscription to scan.", Severity.Warning);
            return;
        }

        _scanning = true;
        _scanComplete = false;
        _orphanedResources.Clear();
        _activeCategory = null;
        StateHasChanged();

        try
        {
            var results = await OrphanedResourceService.ScanForOrphanedResourcesAsync(_selectedSubscriptions);
            _orphanedResources = results.ToList();
            _scanComplete = true;

            if (_orphanedResources.Count == 0)
            {
                Snackbar.Add("No orphaned resources found!", Severity.Success);
            }
            else
            {
                Snackbar.Add($"Found {_orphanedResources.Count} orphaned resource(s)", Severity.Info);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Scan for orphaned resources failed");
            Snackbar.Add("Scan failed.", Severity.Error);
        }
        finally
        {
            _scanning = false;
            StateHasChanged();
        }
    }

    private void ToggleCategoryFilter(string category)
    {
        _activeCategory = _activeCategory == category ? null : category;
    }

    private static Color GetStateColor(string? state) => state switch
    {
        "Enabled" => Color.Success,
        "Disabled" => Color.Error,
        "Warned" => Color.Warning,
        _ => Color.Default
    };

    /// <summary>
    /// Generates the Azure portal URL for a subscription.
    /// </summary>
    private static string GetAzurePortalUrl(TenantSubscription subscription) =>
        $"https://portal.azure.com/#@{subscription.TenantId}/resource/subscriptions/{subscription.SubscriptionId}/overview";

    /// <summary>
    /// Generates the Azure portal URL for a specific resource.
    /// </summary>
    private static string GetResourcePortalUrl(OrphanedResourceInfo resource) =>
        $"https://portal.azure.com/#@{resource.TenantId}/resource{resource.ResourceId}/overview";

    /// <summary>
    /// Generates the Azure portal URL for a resource group from an orphaned resource.
    /// </summary>
    private static string GetResourceGroupPortalUrl(OrphanedResourceInfo resource) =>
        $"https://portal.azure.com/#@{resource.TenantId}/resource/subscriptions/{resource.SubscriptionId}/resourceGroups/{resource.ResourceGroup}/overview";

    /// <summary>
    /// Generates the Azure portal URL for a subscription from an orphaned resource.
    /// </summary>
    private static string GetSubscriptionPortalUrl(OrphanedResourceInfo resource) =>
        $"https://portal.azure.com/#@{resource.TenantId}/resource/subscriptions/{resource.SubscriptionId}/overview";

    private static Color GetCategoryColor(string category) => category switch
    {
        "Unattached Disk" => Color.Error,
        "Unattached NIC" => Color.Warning,
        "Unassociated Public IP" => Color.Info,
        "Unassociated NSG" => Color.Secondary,
        "Empty Availability Set" => Color.Tertiary,
        "Empty Resource Group" => Color.Dark,
        _ => Color.Default
    };
}
