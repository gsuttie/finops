@page "/costs/hybrid-benefit"
@using FinOps.Models
@using FinOps.Services
@using FinOps.Components.Dialogs
@inject IAzureSubscriptionService SubscriptionService
@inject IHybridBenefitService HybridBenefitService
@inject TenantClientManager TenantClientManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<HybridBenefit> Logger

<PageTitle>Hybrid Benefit</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Azure Hybrid Benefit</MudText>

<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
        @if (!string.IsNullOrEmpty(_homeTenantDisplayName))
        {
            <MudChip T="string" Color="MudBlazor.Color.Primary" Size="MudBlazor.Size.Small" Variant="Variant.Outlined">
                @_homeTenantDisplayName
            </MudChip>
        }
        @foreach (var tenantId in TenantClientManager.ConnectedTenantIds)
        {
            <MudChip T="string" Color="MudBlazor.Color.Secondary" Size="MudBlazor.Size.Small"
                     OnClose="@(async _ => await DisconnectTenant(tenantId))">
                @tenantId
            </MudChip>
        }
        <MudButton Variant="Variant.Outlined" Color="MudBlazor.Color.Secondary" Size="MudBlazor.Size.Small"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="@OpenConnectTenantDialog">
            Connect Tenant
        </MudButton>
    </MudStack>
</MudPaper>

<MudTable T="TenantSubscription" Items="@_filteredSubscriptions" Loading="@_loading"
          Hover="true" Dense="true" Elevation="2" Class="mb-4"
          MultiSelection="true" @bind-SelectedItems="_selectedSubscriptions">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Subscriptions</MudText>
        <MudSpacer />
        <MudTextField T="string" @bind-Value="_searchText" Placeholder="Search subscriptions..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="MudBlazor.Size.Medium" Immediate="true"
                      Class="mr-4" Style="max-width: 300px;" />
        <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary"
                   StartIcon="@Icons.Material.Filled.Search"
                   OnClick="@RunScan"
                   Disabled="@(_selectedSubscriptions.Count == 0 || _loadingAnalysis)">
            Scan
        </MudButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Tenant</MudTh>
        <MudTh>Name</MudTh>
        <MudTh>Subscription ID</MudTh>
        <MudTh>State</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Tenant">
            <MudText Typo="Typo.body2"><strong>@context.TenantDisplayName</strong></MudText>
            <MudText Typo="Typo.caption" Style="font-family: monospace;">@context.TenantId</MudText>
        </MudTd>
        <MudTd DataLabel="Name">
            <MudLink Href="@GetSubscriptionPortalUrl(context)" Target="_blank" Typo="Typo.body2">
                @context.DisplayName
            </MudLink>
        </MudTd>
        <MudTd DataLabel="Subscription ID">
            <MudLink Href="@GetSubscriptionPortalUrl(context)" Target="_blank" Typo="Typo.body2" Style="font-family: monospace;">
                @context.SubscriptionId
            </MudLink>
        </MudTd>
        <MudTd DataLabel="State">
            <MudChip T="string" Color="@GetStateColor(context.State)" Size="MudBlazor.Size.Small">
                @context.State
            </MudChip>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>No subscriptions found.</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Loading subscriptions...</MudText>
    </LoadingContent>
</MudTable>

@if (_loadingAnalysis)
{
    <div style="text-align: center; padding: 60px;">
        <MudProgressCircular Indeterminate="true" Size="MudBlazor.Size.Large" />
        <MudText Typo="Typo.h6" Color="MudBlazor.Color.Secondary" Class="mt-4">Scanning Windows VMs for Hybrid Benefit...</MudText>
    </div>
}
else if (_analysis is not null)
{
    @* KPI Cards *@
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" sm="3">
            <MudPaper Class="pa-4" Elevation="2" Style="border-left: 4px solid #1976d2;">
                <MudText Typo="Typo.overline" Color="MudBlazor.Color.Secondary">Total Windows VMs</MudText>
                <MudText Typo="Typo.h5" Class="mt-2">@_analysis.TotalWindowsVms</MudText>
                <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">eligible for AHB</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudPaper Class="pa-4" Elevation="2" Style="border-left: 4px solid #4caf50;">
                <MudText Typo="Typo.overline" Color="MudBlazor.Color.Secondary">AHB Enabled</MudText>
                <MudText Typo="Typo.h5" Class="mt-2" Color="MudBlazor.Color.Success">@_analysis.EnabledCount</MudText>
                <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">using existing licences</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudPaper Class="pa-4" Elevation="2" Style="border-left: 4px solid #ff9800;">
                <MudText Typo="Typo.overline" Color="MudBlazor.Color.Secondary">AHB Not Enabled</MudText>
                <MudText Typo="Typo.h5" Class="mt-2" Color="MudBlazor.Color.Warning">@_analysis.NotEnabledCount</MudText>
                <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">paying full PAYG price</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="3">
            @{
                var pct = _analysis.CoveragePercent;
                var coverageColor = pct >= 70 ? "#4caf50" : pct >= 40 ? "#ff9800" : "#f44336";
            }
            <MudPaper Class="pa-4" Elevation="2" Style="@($"border-left: 4px solid {coverageColor};")">
                <MudText Typo="Typo.overline" Color="MudBlazor.Color.Secondary">Coverage</MudText>
                <MudText Typo="Typo.h5" Class="mt-2">@pct.ToString("F1")%</MudText>
                <MudProgressLinear Value="@((double)pct)" Color="@GetCoverageProgressColor(pct)" Class="mt-2" />
                <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">AHB coverage rate</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Filter chips *@
    <MudStack Row="true" Spacing="2" Class="mb-3">
        <MudChip T="string" Color="@(_filter == "all" ? MudBlazor.Color.Primary : MudBlazor.Color.Default)"
                 OnClick="@(() => _filter = "all")" Size="MudBlazor.Size.Small">
            All (@_analysis.TotalWindowsVms)
        </MudChip>
        <MudChip T="string" Color="@(_filter == "enabled" ? MudBlazor.Color.Success : MudBlazor.Color.Default)"
                 OnClick="@(() => _filter = "enabled")" Size="MudBlazor.Size.Small">
            Enabled (@_analysis.EnabledCount)
        </MudChip>
        <MudChip T="string" Color="@(_filter == "not-enabled" ? MudBlazor.Color.Warning : MudBlazor.Color.Default)"
                 OnClick="@(() => _filter = "not-enabled")" Size="MudBlazor.Size.Small">
            Not Enabled (@_analysis.NotEnabledCount)
        </MudChip>
    </MudStack>

    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
        Azure Hybrid Benefit lets you use existing Windows Server licences with Software Assurance on Azure VMs,
        saving up to 40% on the Windows licence cost. VMs listed here are Windows VMs that are eligible.
        Enable AHB on each VM via the portal link.
    </MudAlert>

    <MudTable T="VmHybridBenefitInfo" Items="@_filteredVms" Elevation="2" Dense="true" Hover="true">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Windows VMs</MudText>
            <MudSpacer />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>VM Name</MudTh>
            <MudTh>Resource Group</MudTh>
            <MudTh>Location</MudTh>
            <MudTh>VM Size</MudTh>
            <MudTh>Power State</MudTh>
            <MudTh>Subscription</MudTh>
            <MudTh>Hybrid Benefit</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="VM Name">
                <MudLink Href="@GetVmPortalUrl(context)" Target="_blank" Typo="Typo.body2">
                    @context.Name
                </MudLink>
            </MudTd>
            <MudTd DataLabel="Resource Group">@context.ResourceGroup</MudTd>
            <MudTd DataLabel="Location">@context.Location</MudTd>
            <MudTd DataLabel="VM Size" Style="font-family: monospace; font-size: 0.8em;">@context.VmSize</MudTd>
            <MudTd DataLabel="Power State">
                <MudChip T="string" Color="@GetPowerStateColor(context.PowerState)" Size="MudBlazor.Size.Small">
                    @(context.PowerState ?? "Unknown")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Subscription">@context.SubscriptionName</MudTd>
            <MudTd DataLabel="Hybrid Benefit">
                @if (context.HybridBenefitEnabled)
                {
                    <MudChip T="string" Color="MudBlazor.Color.Success" Size="MudBlazor.Size.Small">Enabled</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="MudBlazor.Color.Warning" Size="MudBlazor.Size.Small">Not Enabled</MudChip>
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No VMs match the current filter.</MudText>
        </NoRecordsContent>
    </MudTable>
}
else if (_loadError is not null)
{
    <MudAlert Severity="Severity.Error">Failed to scan for Hybrid Benefit: @_loadError</MudAlert>
}
else
{
    <MudPaper Class="pa-6" Elevation="2">
        <MudText Typo="Typo.h6" Color="MudBlazor.Color.Secondary" Align="Align.Center">
            Select one or more subscriptions above and click Scan to find Windows VMs eligible for Azure Hybrid Benefit.
        </MudText>
    </MudPaper>
}

@code {
    private List<TenantSubscription> _subscriptions = [];
    private HashSet<TenantSubscription> _selectedSubscriptions = [];
    private HybridBenefitAnalysis? _analysis;
    private bool _loading = true;
    private bool _loadingAnalysis;
    private string? _loadError;
    private string? _homeTenantDisplayName;
    private string _searchText = string.Empty;
    private string _filter = "all";

    private IEnumerable<TenantSubscription> _filteredSubscriptions =>
        string.IsNullOrWhiteSpace(_searchText)
            ? _subscriptions
            : _subscriptions.Where(s =>
                s.DisplayName.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                s.SubscriptionId.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                (s.TenantDisplayName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                s.TenantId.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<VmHybridBenefitInfo> _filteredVms => _filter switch
    {
        "enabled"     => _analysis?.Vms.Where(v => v.HybridBenefitEnabled) ?? [],
        "not-enabled" => _analysis?.Vms.Where(v => !v.HybridBenefitEnabled) ?? [],
        _             => _analysis?.Vms ?? []
    };

    protected override async Task OnInitializedAsync()
    {
        (_, _homeTenantDisplayName) = await TenantClientManager.GetHomeTenantInfoAsync();
        await LoadSubscriptions();
    }

    private async Task LoadSubscriptions()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _subscriptions = (await SubscriptionService.GetSubscriptionsAsync()).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load subscriptions");
            Snackbar.Add("Failed to load subscriptions.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RunScan()
    {
        _loadingAnalysis = true;
        _analysis = null;
        _loadError = null;
        _filter = "all";
        StateHasChanged();

        try
        {
            _analysis = await HybridBenefitService.GetHybridBenefitAnalysisAsync(_selectedSubscriptions);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to scan for hybrid benefit");
            _loadError = ex.Message;
            Snackbar.Add("Failed to scan for Hybrid Benefit.", Severity.Error);
        }
        finally
        {
            _loadingAnalysis = false;
            StateHasChanged();
        }
    }

    private static string GetSubscriptionPortalUrl(TenantSubscription sub) =>
        $"https://portal.azure.com/#@{sub.TenantId}/resource/subscriptions/{sub.SubscriptionId}/overview";

    private static string GetVmPortalUrl(VmHybridBenefitInfo vm) =>
        $"https://portal.azure.com/#@{vm.TenantId}/resource{vm.ResourceId}";

    private static MudBlazor.Color GetStateColor(string? state) => state switch
    {
        "Enabled"  => MudBlazor.Color.Success,
        "Disabled" => MudBlazor.Color.Error,
        "Warned"   => MudBlazor.Color.Warning,
        _          => MudBlazor.Color.Default
    };

    private static MudBlazor.Color GetPowerStateColor(string? state) => state switch
    {
        "VM running"      => MudBlazor.Color.Success,
        "VM deallocated"  => MudBlazor.Color.Default,
        "VM stopped"      => MudBlazor.Color.Default,
        _                 => MudBlazor.Color.Warning
    };

    private static MudBlazor.Color GetCoverageProgressColor(decimal pct) =>
        pct >= 70 ? MudBlazor.Color.Success : pct >= 40 ? MudBlazor.Color.Warning : MudBlazor.Color.Error;

    private async Task OpenConnectTenantDialog()
    {
        var dialog = await DialogService.ShowAsync<ConnectTenantDialog>("Connect Tenant");
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string tenantId })
        {
            TenantClientManager.ConnectTenant(tenantId);
            Snackbar.Add($"Connected to tenant: {tenantId}", Severity.Success);
            await LoadSubscriptions();
        }
    }

    private async Task DisconnectTenant(string tenantId)
    {
        TenantClientManager.DisconnectTenant(tenantId);
        Snackbar.Add($"Disconnected from tenant: {tenantId}", Severity.Info);
        await LoadSubscriptions();
    }
}
