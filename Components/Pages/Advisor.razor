@page "/advisor"
@using FinOps.Models
@using FinOps.Services
@inject IAzureSubscriptionService SubscriptionService
@inject IAdvisorService AdvisorService
@inject TenantClientManager TenantClientManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Advisor Recommendations</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Advisor Recommendations</MudText>

@* Tenant connection bar *@
<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
        @if (!string.IsNullOrEmpty(_homeTenantDisplayName))
        {
            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">
                @_homeTenantDisplayName
            </MudChip>
        }
        @foreach (var tenantId in TenantClientManager.ConnectedTenantIds)
        {
            <MudChip T="string" Color="Color.Secondary" Size="Size.Small" OnClose="@(async _ => await DisconnectTenant(tenantId))">
                @tenantId
            </MudChip>
        }
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="@OpenConnectTenantDialog">
            Connect Tenant
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Refresh" OnClick="@LoadSubscriptions">
            Refresh
        </MudButton>
    </MudStack>
</MudPaper>

@* Subscription selection table *@
<MudTable T="TenantSubscription" Items="@_filteredSubscriptions" MultiSelection="true"
          SelectedItems="_selectedSubscriptions" SelectedItemsChanged="OnSelectedSubscriptionsChanged"
          Loading="@_loadingSubscriptions" Hover="true" Dense="true" Elevation="2">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Subscriptions</MudText>
        <MudSpacer />
        <MudTextField T="string" @bind-Value="_subSearchText" Placeholder="Search subscriptions..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium" Immediate="true" Class="mr-4" Style="max-width: 300px;" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Lightbulb"
                   OnClick="@GetRecommendations">
            Get Recommendations (@_selectedSubscriptions.Count selected)
        </MudButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Tenant</MudTh>
        <MudTh>Name</MudTh>
        <MudTh>Subscription ID</MudTh>
        <MudTh>State</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Tenant">
            <MudText Typo="Typo.body2"><strong>@context.TenantDisplayName</strong></MudText>
            <MudText Typo="Typo.caption" Style="font-family: monospace;">@context.TenantId</MudText>
        </MudTd>
        <MudTd DataLabel="Name">@context.DisplayName</MudTd>
        <MudTd DataLabel="Subscription ID">
            <MudText Typo="Typo.body2" Style="font-family: monospace;">@context.SubscriptionId</MudText>
        </MudTd>
        <MudTd DataLabel="State">
            <MudChip T="string" Color="@GetStateColor(context.State)" Size="Size.Small">
                @context.State
            </MudChip>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        @if (_loadError is not null)
        {
            <MudText Color="Color.Error">@_loadError</MudText>
        }
        else
        {
            <MudText>No subscriptions found.</MudText>
        }
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Loading subscriptions...</MudText>
    </LoadingContent>
</MudTable>

@* Summary *@
@if (_fetchComplete && (_recommendations.Count > 0 || _advisorScores.Count > 0))
{
    <MudPaper Class="pa-3 mt-4 mb-2" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
            @if (_advisorScores.Count > 0)
            {
                var overallScore = Math.Round(_advisorScores.Values.Average(), 0);
                <MudText Typo="Typo.body1" Class="mr-2">
                    <b>Overall Score:</b>
                    <MudChip T="string" Color="@GetScoreColor(overallScore)" Size="Size.Small" Variant="Variant.Filled">
                        @overallScore.ToString("F0")%
                    </MudChip>
                </MudText>
                <MudDivider Vertical="true" FlexItem="true" />
            }
            <MudText Typo="Typo.body1" Class="mr-2"><b>@_recommendations.Count</b> recommendations found</MudText>
            @foreach (var group in _categoryCounts)
            {
                <MudChip T="string" Color="@GetCategoryColor(group.Key)" Size="Size.Small" Variant="Variant.Outlined">
                    @GetCategoryDisplayName(group.Key) (@group.Value)
                </MudChip>
            }
        </MudStack>
    </MudPaper>
}

@* Results by Category *@
@if (_fetchComplete)
{
    <MudExpansionPanels MultiExpansion="true" Class="mt-4">
        @foreach (var category in new[] { "Cost", "Security", "HighAvailability", "OperationalExcellence", "Performance" })
        {
            var categoryRecommendations = GetRecommendationsByCategory(category);

            <MudExpansionPanel>
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-grow-1">
                            <MudIcon Icon="@GetCategoryIcon(category)" Color="@GetCategoryColor(category)" />
                            <MudText Typo="Typo.h6">@GetCategoryDisplayName(category)</MudText>
                            @if (_advisorScores.TryGetValue(category, out var score))
                            {
                                <MudChip T="string" Color="@GetScoreColor(score)" Size="Size.Small" Variant="Variant.Filled">
                                    @score.ToString("F0")%
                                </MudChip>
                            }
                            @if (categoryRecommendations.Any())
                            {
                                <MudChip T="string" Color="@GetCategoryColor(category)" Size="Size.Small" Variant="Variant.Outlined">
                                    @categoryRecommendations.Count() @(categoryRecommendations.Count() == 1 ? "issue" : "issues")
                                </MudChip>
                            }
                            <MudSpacer />
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        @if (categoryRecommendations.Any())
                        {
                            <MudTable T="AdvisorRecommendation" Items="@categoryRecommendations" Hover="true" Dense="true" Elevation="0">
                                <HeaderContent>
                                    <MudTh><MudTableSortLabel T="AdvisorRecommendation" SortBy="@(new Func<AdvisorRecommendation, object>(x => x.Impact))">Impact</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel T="AdvisorRecommendation" SortBy="@(new Func<AdvisorRecommendation, object>(x => x.Problem))">Problem</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel T="AdvisorRecommendation" SortBy="@(new Func<AdvisorRecommendation, object>(x => x.Solution))">Solution</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel T="AdvisorRecommendation" SortBy="@(new Func<AdvisorRecommendation, object>(x => x.ImpactedValue))">Impacted Resource</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel T="AdvisorRecommendation" SortBy="@(new Func<AdvisorRecommendation, object>(x => x.SubscriptionName))">Subscription</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel T="AdvisorRecommendation" SortBy="@(new Func<AdvisorRecommendation, object>(x => x.LastUpdated ?? DateTimeOffset.MinValue))">Last Updated</MudTableSortLabel></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Impact">
                                        <MudChip T="string" Color="@GetImpactColor(context.Impact)" Size="Size.Small">
                                            @context.Impact
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Problem">@context.Problem</MudTd>
                                    <MudTd DataLabel="Solution">@context.Solution</MudTd>
                                    <MudTd DataLabel="Impacted Resource">
                                        <MudText Typo="Typo.body2">@context.ImpactedValue</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.ImpactedField</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="Subscription">@context.SubscriptionName</MudTd>
                                    <MudTd DataLabel="Last Updated">@(context.LastUpdated?.ToString("yyyy-MM-dd") ?? "—")</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="ma-2">
                                <MudText Typo="Typo.body1">No recommendations — great work!</MudText>
                            </MudAlert>
                        }
                    </ChildContent>
                </MudExpansionPanel>
        }
    </MudExpansionPanels>

    @if (!_recommendations.Any())
    {
        <MudPaper Class="pa-4 mt-4" Elevation="2">
            <MudText Typo="Typo.body1" Align="Align.Center">No recommendations found — looking good!</MudText>
        </MudPaper>
    }
}

@if (_fetching)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-4" />
    <MudText Typo="Typo.body2" Class="mt-2" Align="Align.Center">Fetching advisor recommendations...</MudText>
}

@code {
    private List<TenantSubscription> _subscriptions = [];
    private HashSet<TenantSubscription> _selectedSubscriptions = [];
    private List<AdvisorRecommendation> _recommendations = [];
    private Dictionary<string, double> _advisorScores = new();
    private bool _loadingSubscriptions = true;
    private bool _fetching;
    private bool _fetchComplete;
    private string? _loadError;
    private string _subSearchText = string.Empty;
    private string? _homeTenantId;
    private string? _homeTenantDisplayName;

    private IEnumerable<TenantSubscription> _filteredSubscriptions =>
        string.IsNullOrWhiteSpace(_subSearchText)
            ? _subscriptions
            : _subscriptions.Where(s =>
                s.DisplayName.Contains(_subSearchText, StringComparison.OrdinalIgnoreCase) ||
                s.SubscriptionId.Contains(_subSearchText, StringComparison.OrdinalIgnoreCase) ||
                (s.TenantDisplayName?.Contains(_subSearchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                s.TenantId.Contains(_subSearchText, StringComparison.OrdinalIgnoreCase));

    private Dictionary<string, int> _categoryCounts =>
        _recommendations
            .GroupBy(r => r.Category)
            .OrderByDescending(g => g.Count())
            .ToDictionary(g => g.Key, g => g.Count());

    private IEnumerable<AdvisorRecommendation> GetRecommendationsByCategory(string category) =>
        _recommendations.Where(r => r.Category == category).OrderByDescending(r => r.Impact);

    protected override async Task OnInitializedAsync()
    {
        (_homeTenantId, _homeTenantDisplayName) = await TenantClientManager.GetHomeTenantInfoAsync();
        await LoadSubscriptions();
    }

    private async Task LoadSubscriptions()
    {
        _loadingSubscriptions = true;
        _loadError = null;
        _selectedSubscriptions.Clear();
        StateHasChanged();

        try
        {
            _subscriptions = (await SubscriptionService.GetSubscriptionsAsync()).ToList();
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load subscriptions: {ex.Message}";
        }
        finally
        {
            _loadingSubscriptions = false;
        }
    }

    private async Task OpenConnectTenantDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<FinOps.Components.Dialogs.ConnectTenantDialog>("Connect Tenant", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string tenantId })
        {
            Snackbar.Add($"Connected to tenant {tenantId}", Severity.Success);
            await LoadSubscriptions();
        }
    }

    private async Task DisconnectTenant(string tenantId)
    {
        TenantClientManager.DisconnectTenant(tenantId);
        Snackbar.Add($"Disconnected from tenant {tenantId}", Severity.Info);
        await LoadSubscriptions();
    }

    private void OnSelectedSubscriptionsChanged(HashSet<TenantSubscription> selected)
    {
        _selectedSubscriptions = selected;
    }

    private async Task GetRecommendations()
    {
        if (_selectedSubscriptions.Count == 0)
        {
            Snackbar.Add("Please select at least one subscription.", Severity.Warning);
            return;
        }

        _fetching = true;
        _fetchComplete = false;
        _recommendations.Clear();
        _advisorScores.Clear();
        StateHasChanged();

        try
        {
            // Fetch recommendations and scores in parallel
            var recommendationsTask = AdvisorService.GetRecommendationsAsync(_selectedSubscriptions);
            var scoresTask = AdvisorService.GetAdvisorScoresAsync(_selectedSubscriptions);

            await Task.WhenAll(recommendationsTask, scoresTask);

            _recommendations = recommendationsTask.Result.ToList();
            _advisorScores = scoresTask.Result;
            _fetchComplete = true;

            if (_recommendations.Count == 0)
            {
                Snackbar.Add("No recommendations found!", Severity.Success);
            }
            else
            {
                Snackbar.Add($"Found {_recommendations.Count} recommendation(s)", Severity.Info);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to fetch recommendations: {ex.Message}", Severity.Error);
        }
        finally
        {
            _fetching = false;
            StateHasChanged();
        }
    }

    private static string GetCategoryDisplayName(string category) => category switch
    {
        "HighAvailability" => "Reliability",
        "OperationalExcellence" => "Operational Excellence",
        _ => category
    };

    private static string GetCategoryIcon(string category) => category switch
    {
        "Cost" => Icons.Material.Filled.AttachMoney,
        "Security" => Icons.Material.Filled.Security,
        "HighAvailability" => Icons.Material.Filled.HealthAndSafety,
        "OperationalExcellence" => Icons.Material.Filled.Settings,
        "Performance" => Icons.Material.Filled.Speed,
        _ => Icons.Material.Filled.Info
    };

    private static Color GetScoreColor(double score) => score switch
    {
        >= 80 => Color.Success,
        >= 60 => Color.Warning,
        _ => Color.Error
    };

    private static Color GetStateColor(string? state) => state switch
    {
        "Enabled" => Color.Success,
        "Disabled" => Color.Error,
        "Warned" => Color.Warning,
        _ => Color.Default
    };

    private static Color GetCategoryColor(string category) => category switch
    {
        "Cost" => Color.Success,
        "Security" => Color.Error,
        "HighAvailability" => Color.Warning,
        "OperationalExcellence" => Color.Info,
        "Performance" => Color.Primary,
        _ => Color.Default
    };

    private static Color GetImpactColor(string impact) => impact switch
    {
        "High" => Color.Error,
        "Medium" => Color.Warning,
        "Low" => Color.Info,
        _ => Color.Default
    };
}
