@page "/budgets"
@using FinOps.Models
@using FinOps.Services
@inject IAzureSubscriptionService SubscriptionService
@inject IBudgetService BudgetService
@inject TenantClientManager TenantClientManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Budgets</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Subscription Budgets</MudText>


<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap">
        <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">
            Home / Lighthouse
        </MudChip>
        @foreach (var tenantId in TenantClientManager.ConnectedTenantIds)
        {
            <MudChip T="string" Color="Color.Secondary" Size="Size.Small" OnClose="@(async _ => await DisconnectTenant(tenantId))">
                @tenantId
            </MudChip>
        }
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="@OpenConnectTenantDialog">
            Connect Tenant
        </MudButton>
    </MudStack>
</MudPaper>

<MudTable T="TenantSubscription" Items="@_filteredSubscriptions" MultiSelection="true"
          SelectedItems="_selectedSubscriptions" SelectedItemsChanged="OnSelectedSubscriptionsChanged"
          Loading="@_loading" Hover="true" Dense="true" Elevation="2">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Subscriptions</MudText>
        <MudSpacer />
        <MudTextField T="string" @bind-Value="_searchText" Placeholder="Search subscriptions..." Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                      Immediate="true" Class="mr-4" Style="max-width: 300px;" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@OpenCreateBudgetDialog">
            Create Budget (@_selectedSubscriptions.Count selected)
        </MudButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Tenant</MudTh>
        <MudTh>Name</MudTh>
        <MudTh>Subscription ID</MudTh>
        <MudTh>State</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Tenant">
            <MudChip T="string" Color="@(context.IsDefault ? Color.Primary : Color.Secondary)" Size="Size.Small">
                @(context.TenantDisplayName ?? context.TenantId)
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Name">@context.DisplayName</MudTd>
        <MudTd DataLabel="Subscription ID">
            <MudText Typo="Typo.body2" Style="font-family: monospace;">@context.SubscriptionId</MudText>
        </MudTd>
        <MudTd DataLabel="State">
            <MudChip T="string" Color="@GetStateColor(context.State)" Size="Size.Small">
                @context.State
            </MudChip>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        @if (_loadError is not null)
        {
            <MudText Color="Color.Error">@_loadError</MudText>
        }
        else
        {
            <MudText>No subscriptions found.</MudText>
        }
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Loading subscriptions...</MudText>
    </LoadingContent>
</MudTable>

@if (_results.Count > 0)
{
    <MudText Typo="Typo.h6" Class="mt-4 mb-2">Budget Creation Results</MudText>
    <MudTable T="BudgetCreationResult" Items="@_results" Hover="true" Dense="true" Elevation="2">
        <HeaderContent>
            <MudTh>Subscription</MudTh>
            <MudTh>Subscription ID</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Details</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Subscription">@context.SubscriptionName</MudTd>
            <MudTd DataLabel="Subscription ID">
                <MudText Typo="Typo.body2" Style="font-family: monospace;">@context.SubscriptionId</MudText>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Color="@(context.Success ? Color.Success : Color.Error)" Size="Size.Small">
                    @(context.Success ? "Success" : "Failed")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Details">
                @if (!context.Success)
                {
                    <MudText Typo="Typo.body2" Color="Color.Error">@context.ErrorMessage</MudText>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@if (_selectedSubscriptions.Count > 0)
{
    <MudTable T="BudgetInfo" Items="@_existingBudgets" Loading="@_loadingBudgets"
              Hover="true" Dense="true" Elevation="2" Class="mt-4">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Existing Budgets</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="@LoadExistingBudgets">
                Refresh
            </MudButton>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Subscription</MudTh>
            <MudTh><MudTableSortLabel T="BudgetInfo" SortBy="@(new Func<BudgetInfo, object>(x => x.Name))">Name</MudTableSortLabel></MudTh>
            <MudTh>Amount</MudTh>
            <MudTh>Current Spend</MudTh>
            <MudTh>Time Grain</MudTh>
            <MudTh>Start Date</MudTh>
            <MudTh>End Date</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Subscription">@context.SubscriptionName</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Amount">@(context.Amount?.ToString("C2"))</MudTd>
            <MudTd DataLabel="Current Spend">
                @if (context.CurrentSpend.HasValue && context.Amount.HasValue && context.Amount.Value > 0)
                {
                    var pct = context.CurrentSpend.Value / context.Amount.Value * 100;
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.body2">@context.CurrentSpend.Value.ToString("C2")</MudText>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(pct > 90 ? Color.Error : pct > 70 ? Color.Warning : Color.Success)">
                            @pct.ToString("F0")%
                        </MudChip>
                    </MudStack>
                }
                else
                {
                    <MudText Typo="Typo.body2">@(context.CurrentSpend?.ToString("C2") ?? "-")</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Time Grain">@context.TimeGrain</MudTd>
            <MudTd DataLabel="Start Date">@(context.StartDate?.ToString("dd MMM yyyy") ?? "-")</MudTd>
            <MudTd DataLabel="End Date">@(context.EndDate?.ToString("dd MMM yyyy") ?? "-")</MudTd>
            <MudTd DataLabel="Actions">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                               Size="Size.Small" OnClick="@(() => DeleteBudget(context))" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No existing budgets found for the selected subscription(s).</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Loading budgets...</MudText>
        </LoadingContent>
    </MudTable>
}

@code {
    private List<TenantSubscription> _subscriptions = [];
    private HashSet<TenantSubscription> _selectedSubscriptions = [];
    private List<BudgetCreationResult> _results = [];
    private List<BudgetInfo> _existingBudgets = [];
    private bool _loading = true;
    private bool _loadingBudgets;
    private bool _creating;
    private string? _loadError;
    private string _searchText = string.Empty;

    /// <summary>
    /// Filters subscriptions by display name, subscription ID, tenant name, or tenant ID based on the search text.
    /// </summary>
    private IEnumerable<TenantSubscription> _filteredSubscriptions =>
        string.IsNullOrWhiteSpace(_searchText)
            ? _subscriptions
            : _subscriptions.Where(s =>
                s.DisplayName.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                s.SubscriptionId.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                (s.TenantDisplayName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                s.TenantId.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        await LoadSubscriptions();
    }

    /// <summary>
    /// Loads all subscriptions from the home tenant and any connected tenants.
    /// Clears the current selection and resets error state.
    /// </summary>
    private async Task LoadSubscriptions()
    {
        _loading = true;
        _loadError = null;
        _selectedSubscriptions.Clear();
        StateHasChanged();

        try
        {
            _subscriptions = (await SubscriptionService.GetSubscriptionsAsync()).ToList();
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load subscriptions: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    /// <summary>
    /// Opens the Connect Tenant dialog and, on success, registers the new tenant and reloads subscriptions.
    /// </summary>
    private async Task OpenConnectTenantDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<FinOps.Components.Dialogs.ConnectTenantDialog>("Connect Tenant", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string tenantId })
        {
            TenantClientManager.ConnectTenant(tenantId);
            Snackbar.Add($"Connected to tenant {tenantId}", Severity.Success);
            await LoadSubscriptions();
        }
    }

    /// <summary>
    /// Removes a connected tenant and reloads the subscription list.
    /// </summary>
    /// <param name="tenantId">The Azure AD tenant ID to disconnect.</param>
    private async Task DisconnectTenant(string tenantId)
    {
        TenantClientManager.DisconnectTenant(tenantId);
        Snackbar.Add($"Disconnected from tenant {tenantId}", Severity.Info);
        await LoadSubscriptions();
    }

    /// <summary>
    /// Handles subscription table selection changes; loads existing budgets for the newly selected subscriptions.
    /// </summary>
    /// <param name="selected">The updated set of selected subscriptions.</param>
    private async Task OnSelectedSubscriptionsChanged(HashSet<TenantSubscription> selected)
    {
        _selectedSubscriptions = selected;
        _existingBudgets.Clear();

        if (selected.Count > 0)
        {
            await LoadExistingBudgets();
        }
    }

    /// <summary>
    /// Retrieves existing Azure Consumption budgets for all currently selected subscriptions.
    /// </summary>
    private async Task LoadExistingBudgets()
    {
        _loadingBudgets = true;
        StateHasChanged();

        try
        {
            var allBudgets = new List<BudgetInfo>();
            foreach (var sub in _selectedSubscriptions)
            {
                var budgets = await BudgetService.GetBudgetsAsync(sub);
                allBudgets.AddRange(budgets);
            }
            _existingBudgets = allBudgets;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load budgets: {ex.Message}", Severity.Error);
            _existingBudgets.Clear();
        }
        finally
        {
            _loadingBudgets = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Opens the Create Budget dialog and applies the budget to all selected subscriptions on confirmation.
    /// Displays per-subscription results and refreshes the existing budgets table.
    /// </summary>
    private async Task OpenCreateBudgetDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<FinOps.Components.Dialogs.CreateBudgetDialog>("Create Budget", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: BudgetFormModel form })
        {
            _creating = true;
            StateHasChanged();

            try
            {
                var creationResults = await BudgetService.CreateBudgetForSubscriptionsAsync(
                    _selectedSubscriptions, form);
                _results = creationResults.ToList();

                var succeeded = _results.Count(r => r.Success);
                var failed = _results.Count(r => !r.Success);

                if (failed == 0)
                {
                    Snackbar.Add($"Budget created for all {succeeded} subscription(s)", Severity.Success);
                }
                else
                {
                    Snackbar.Add($"{succeeded} succeeded, {failed} failed", Severity.Warning);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error creating budget: {ex.Message}", Severity.Error);
            }
            finally
            {
                _creating = false;
                await LoadExistingBudgets();
            }
        }
    }

    /// <summary>
    /// Prompts the user for confirmation, then deletes the specified budget from Azure.
    /// </summary>
    /// <param name="budget">The budget to delete.</param>
    private async Task DeleteBudget(BudgetInfo budget)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Delete Budget",
            $"Are you sure you want to delete budget '{budget.Name}' from {budget.SubscriptionName}?",
            yesText: "Delete", cancelText: "Cancel");

        if (confirm != true) return;

        try
        {
            await BudgetService.DeleteBudgetAsync(budget);
            Snackbar.Add($"Budget '{budget.Name}' deleted", Severity.Success);
            await LoadExistingBudgets();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to delete budget: {ex.Message}", Severity.Error);
        }
    }

    /// <summary>
    /// Maps a subscription state string to a MudBlazor color for visual indication.
    /// </summary>
    private static Color GetStateColor(string? state) => state switch
    {
        "Enabled" => Color.Success,
        "Disabled" => Color.Error,
        "Warned" => Color.Warning,
        _ => Color.Default
    };
}
